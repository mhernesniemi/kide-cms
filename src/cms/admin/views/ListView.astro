---
import { Plus } from "lucide-react";

import DocumentsDataTable, { PAGE_SIZE } from "@/cms/admin/components/DocumentsDataTable";
import { buttonVariants } from "@/cms/admin/components/ui/button";
import config from "virtual:kide/config";
import { cms } from "virtual:kide/api";
import { collaboration } from "virtual:kide/runtime";
import { REVIEW_STATE_META } from "@/cms/admin/lib/collaboration";
import {
  formatDate,
  formatFieldValue,
  getLabelField,
  getListColumns,
  humanize,
  resolveCollaboration,
} from "@/cms/core";
import { canWrite, getVisualStatus } from "@/cms/admin/lib/access";
import { loadRelationOptionList, loadSharedSectionUsageCounts } from "@/cms/admin/lib/edit-data";

type CollectionLike = {
  slug: string;
  labels: { singular: string; plural: string };
  drafts?: boolean;
  fields: Record<string, any>;
  views?: Record<string, any>;
};

const { collection } = Astro.props as { collection: CollectionLike };
const user = Astro.locals.user;
const runtimeContext = user ? { user: { id: user.id, role: user.role, email: user.email } } : {};
const cmsRuntime = cms as Record<string, any>;
const defaultLocale = config.locales?.default ?? "en";
const locales = config.locales?.supported ?? [];

const viewConfig = collection.views ?? {};
const defaultSort = viewConfig.list?.defaultSort ?? { field: "_updatedAt", direction: "desc" };
const sortParam = Astro.url.searchParams.get("sort");
const sortDirParam = Astro.url.searchParams.get("dir");
const currentSort = sortParam
  ? { field: sortParam, direction: (sortDirParam === "asc" ? "asc" : "desc") as "asc" | "desc" }
  : defaultSort;
const currentPage = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1"));
const searchParam = Astro.url.searchParams.get("q") ?? "";
const offset = (currentPage - 1) * PAGE_SIZE;

const collectionApi = cmsRuntime[collection.slug];
const [docs, totalDocs] = await Promise.all([
  collectionApi.find(
    {
      status: "any",
      locale: defaultLocale,
      sort: currentSort,
      limit: PAGE_SIZE,
      offset,
      search: searchParam || undefined,
    },
    runtimeContext,
  ),
  collectionApi.count({ status: "any", locale: defaultLocale, search: searchParam || undefined }, runtimeContext),
]);
const totalPages = Math.max(1, Math.ceil(totalDocs / PAGE_SIZE));

const listColumns = getListColumns(collection, viewConfig.list);

// Resolve relation columns to their related document labels (id → label) so the
// table shows e.g. the form title instead of the raw relation id.
const relationLabels: Record<string, string> = {};
for (const column of listColumns) {
  const field = collection.fields[column];
  if (field?.type !== "relation") continue;
  const options = await loadRelationOptionList(
    field.collection,
    config,
    cmsRuntime as any,
    defaultLocale,
    runtimeContext,
  );
  for (const option of options) relationLabels[option.value] = option.label;
}

// Collaboration columns (review state + assignee) — only for collections in the
// collaboration list that also support drafts. Not sortable (non-DB columns).
const collabListColumns =
  resolveCollaboration(config, collection.slug).enabled && collection.drafts ? ["__review", "__assignee"] : [];
const displayColumns = [...listColumns, ...collabListColumns];

// Batch-load review state + assignee for the listed documents.
let collabStates: Record<string, { reviewState: string; assignee: string | null }> = {};
const collabUserNames: Record<string, string> = {};
if (collabListColumns.length > 0) {
  collabStates = await collaboration.getStatesForDocs(
    collection.slug,
    docs.map((entry: Record<string, unknown>) => String(entry._id)),
  );
  const assigneeIds = [
    ...new Set(
      Object.values(collabStates)
        .map((s) => s.assignee)
        .filter((id): id is string => Boolean(id)),
    ),
  ];
  if (assigneeIds.length > 0) {
    const users = await cmsRuntime.users?.find({ status: "any", limit: 100 }, runtimeContext).catch(() => []);
    for (const u of users ?? []) collabUserNames[String(u._id)] = String(u.name ?? u.email ?? u._id);
  }
}

const sharedSectionUsageCounts =
  collection.slug === "shared-sections"
    ? await loadSharedSectionUsageCounts(
        docs.map((entry: Record<string, unknown>) => String(entry._id)),
        config,
        user,
        cmsRuntime as any,
        defaultLocale,
        runtimeContext,
      )
    : {};
const tableRows = docs.map((entry: Record<string, unknown>) => ({
  id: String(entry._id),
  editHref: `/admin/${collection.slug}/${entry._id}`,
  status: getVisualStatus(entry),
  locales: [
    defaultLocale,
    ...(Array.isArray(entry._availableLocales)
      ? entry._availableLocales.map((l) => String(l)).filter((l) => l !== defaultLocale)
      : []),
  ],
  searchText: String(entry[getLabelField(collection)] ?? entry.slug ?? entry._id ?? ""),
  values: Object.fromEntries(
    displayColumns.map((column) => [
      column,
      column === "__review"
        ? REVIEW_STATE_META[
            (collabStates[String(entry._id)]?.reviewState ?? "in_progress") as keyof typeof REVIEW_STATE_META
          ].label
        : column === "__assignee"
          ? collabStates[String(entry._id)]?.assignee
            ? (collabUserNames[collabStates[String(entry._id)]!.assignee!] ?? "—")
            : "Unassigned"
          : column === "_status"
            ? getVisualStatus(entry)
            : column === "__usage"
              ? `${sharedSectionUsageCounts[String(entry._id)] ?? 0} places`
              : column === "_updatedAt" || column === "_createdAt"
                ? formatDate(entry[column])
                : column.startsWith("_")
                  ? String(entry[column] ?? "—")
                  : formatFieldValue(collection.fields[column], entry[column], relationLabels),
    ]),
  ),
}));
---

<section class="space-y-6 px-4 py-6 lg:py-8 lg:pr-8 lg:pl-12">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">{collection.labels.plural}</h1>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      {
        canWrite(config, user, collection.slug) && (
          <a href={`/admin/${collection.slug}/new`} class={buttonVariants({})}>
            <Plus className="size-4" />
            {collection.slug === "users" ? "Invite user" : `New ${collection.labels.singular}`}
          </a>
        )
      }
    </div>
  </div>
  <DocumentsDataTable
    client:load
    collectionSlug={collection.slug}
    draftsEnabled={collection.drafts}
    defaultLocale={locales.length > 1 ? defaultLocale : undefined}
    labelField={getLabelField(collection)}
    newHref={`/admin/${collection.slug}/new`}
    title={collection.labels.plural}
    columns={displayColumns.map((column) => ({
      key: column,
      label:
        column === "__usage"
          ? "Used in"
          : column === "__review"
            ? "Review"
            : column === "__assignee"
              ? "Assignee"
              : humanize(column),
      sortable: !column.startsWith("__"),
    }))}
    data={tableRows}
    searchPlaceholder={`Filter ${collection.labels.plural.toLowerCase()}...`}
    serverPagination={{
      totalDocs,
      totalPages,
      currentPage,
      currentSort,
      currentSearch: searchParam,
    }}
  />
</section>
