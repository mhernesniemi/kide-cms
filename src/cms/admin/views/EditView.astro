---
import { ArrowLeft, ArrowUpRight, Dot } from "lucide-react";

import AdminCard from "@/cms/admin/components/AdminCard.astro";
import AiGenerateButton from "@/cms/admin/components/AiGenerateButton";
import DocumentActions from "@/cms/admin/components/DocumentActions";
import DocumentLock from "@/cms/admin/components/DocumentLock";
import LiveHeading from "@/cms/admin/components/LiveHeading";
import UnsavedGuard from "@/cms/admin/components/UnsavedGuard";
import FieldControl from "@/cms/admin/components/FieldControl.astro";
import { StatusBadge } from "@/cms/admin/components/ui/badge";
import { buttonVariants } from "@/cms/admin/components/ui/button";
import config from "virtual:kide/config";
import { cms } from "virtual:kide/api";
import { isAiEnabled } from "virtual:kide/runtime";
import { formatDate, getFieldSets, getLabelField, getSharedBlockTypes } from "@/cms/core";
import {
  getFormAction,
  getVisualStatus,
  isFieldHidden as isFieldHiddenFn,
  isFieldReadOnly as isFieldReadOnlyFn,
} from "@/cms/admin/lib/access";
import {
  loadDocument,
  loadMenuLinkOptions,
  loadParentFormTitle,
  loadRelationOptions,
  loadReverseRefs,
  loadSharedBlockRelationOptions,
  loadSharedSectionOptions,
} from "@/cms/admin/lib/edit-data";
import EditScripts from "./edit/EditScripts.astro";
import ReverseReferencesList from "./edit/ReverseReferencesList.astro";

type CollectionLike = {
  slug: string;
  labels: { singular: string; plural: string };
  singleton?: boolean;
  drafts?: boolean;
  preview?: boolean | string;
  pathPrefix?: string;
  fields: Record<string, any>;
};

const {
  collection,
  mode,
  documentId,
  variant = "editorial",
} = Astro.props as {
  collection: CollectionLike;
  mode: "new" | "edit";
  documentId?: string;
  // "editorial" = sticky bar + flowing fields (content collections & singletons);
  // "record" = plain header + card-wrapped fields (library/system collections).
  variant?: "editorial" | "record";
};

const user = Astro.locals.user;
const runtimeContext = user ? { user: { id: user.id, role: user.role, email: user.email } } : {};
const cmsRuntime = cms as Record<string, any> & { meta: typeof cms.meta };
const locales = config.locales?.supported ?? [];
const defaultLocale = config.locales?.default ?? "en";
const requestedLocale = Astro.url.searchParams.get("locale") ?? defaultLocale;
const aiEnabled = isAiEnabled();
const collectionApi = cmsRuntime[collection.slug];
const isSingleton = collection.singleton === true;

const isFieldHidden = (fieldName: string) => isFieldHiddenFn(collection, user, fieldName);
const isFieldReadOnly = (fieldName: string) => isFieldReadOnlyFn(collection, user, fieldName);

// --- Data loading ---
let doc: Record<string, unknown> | null = null;
let baseDoc: Record<string, unknown> | null = null;
let versions: Array<{ version: number; createdAt: string }> = [];
if (mode === "edit" && documentId) {
  try {
    const loaded = await loadDocument(collectionApi, documentId, requestedLocale, defaultLocale, runtimeContext);
    if (!loaded.doc) return Astro.redirect(`/admin/${collection.slug}`);
    doc = loaded.doc;
    baseDoc = loaded.baseDoc;
    versions = loaded.versions;
  } catch {
    return Astro.redirect(`/admin/${collection.slug}?_toast=error&_msg=Access+denied`);
  }
}

const { relationOptionsByField, relationMetaByField } = await loadRelationOptions(
  collection,
  config,
  user,
  cmsRuntime,
  defaultLocale,
  runtimeContext,
);
const sharedBlockTypes = getSharedBlockTypes(config);
const [sharedBlockRelationOptions, sharedSectionOptions] = await Promise.all([
  loadSharedBlockRelationOptions(config, user, cmsRuntime, defaultLocale, runtimeContext),
  loadSharedSectionOptions(config, user, cmsRuntime, defaultLocale, runtimeContext),
]);
const menuLinkOptions =
  collection.slug === "menus" ? await loadMenuLinkOptions(config, user, cmsRuntime, defaultLocale, runtimeContext) : [];
const reverseRefs =
  mode === "edit" && documentId
    ? await loadReverseRefs(collection, documentId, config, user, cmsRuntime, defaultLocale, runtimeContext)
    : [];

// Submissions live in their own sidebar section now, not as a tab on the form.
const formTab = "edit" as "edit" | "submissions";

// --- Form-submissions-specific: custom read-only view ---
const isSubmissionView = collection.slug === "form-submissions" && mode === "edit";
const parentFormTitle =
  isSubmissionView && doc?.form ? await loadParentFormTitle(String(doc.form), cmsRuntime, runtimeContext) : null;
const submissionData = (isSubmissionView && doc?.data ? doc.data : {}) as Record<string, unknown>;
const { _context: submissionContext, ...submittedFields } = submissionData;
const submissionContextEntries =
  submissionContext && typeof submissionContext === "object"
    ? Object.entries(submissionContext as Record<string, unknown>)
    : [];
const formatSubmissionValue = (value: unknown): string => {
  if (value === null || value === undefined) return "—";
  if (typeof value === "boolean") return value ? "Yes" : "No";
  if (typeof value === "string") return value;
  return JSON.stringify(value);
};

// --- Layout / derived state ---
const selectedLocale = mode === "new" ? defaultLocale : requestedLocale;
const translatableFields = Object.entries(collection.fields)
  .filter(([, field]: [string, any]) => field.translatable)
  .map(([fieldName]) => fieldName);
const translationMode = mode === "edit" && selectedLocale !== defaultLocale && translatableFields.length > 0;
const fieldSets = getFieldSets(collection);
const primaryFieldSets = fieldSets.filter((set: { position?: string }) => set.position !== "sidebar");
const sidebarFieldSets = fieldSets.filter((set: { position?: string }) => set.position === "sidebar");
const mainFieldSets = primaryFieldSets.length > 0 ? primaryFieldSets : fieldSets.slice(0, 1);
const effectiveSidebarFieldSets =
  sidebarFieldSets.length > 0 ? sidebarFieldSets : fieldSets.slice(mainFieldSets.length);

// Document metadata (created/updated, scheduled publish) shown at the bottom of
// the sidebar under the label info.
const hasDocMeta = Boolean(mode === "edit" && doc && collection.drafts);

// Editable fields that live in the sidebar (slug, category, etc.). The meta
// group (Referenced by / Info) only draws a top divider when these exist above it.
const hasSidebarFields = effectiveSidebarFieldSets.some((set) =>
  set.fields.some((fieldName) => collection.fields[fieldName] && !isFieldHidden(fieldName)),
);
const hasSidebarMeta = reverseRefs.length > 0 || hasDocMeta;

// Whether to render the right-hand sidebar column at all (avoids a stray sticky
// border on collections with no sidebar fields and no incoming references).
const hasSidebarColumn = !isSubmissionView && (hasSidebarFields || hasSidebarMeta);

const hasPreview = !!(mode === "edit" && (collection.preview || (collection.pathPrefix && doc?.slug)));
const previewUrl = hasPreview
  ? typeof collection.preview === "string"
    ? `${collection.preview}?preview=true`
    : `${cms.meta.getRouteForDocument(collection.slug, doc)}?preview=true`
  : null;

const getCurrentValue = (fieldName: string) => (doc ? doc[fieldName] : undefined);
const getSharedValue = (fieldName: string) => (baseDoc ? baseDoc[fieldName] : undefined);
const blockRelationOptions: Record<string, Array<{ value: string; label: string }>> = {};
for (const [key, opts] of Object.entries(relationOptionsByField)) {
  if (key.startsWith("block:")) blockRelationOptions[key] = opts;
}
---

<section class="space-y-14">
  {
    /* ── Sticky action bar ─────────────────────────────────────────────────
     Title + status on the left, primary actions on the right. Stays pinned so
     Save / Publish stay reachable while editing long documents. */
  }
  <div
    class:list={[
      "border-b px-4 py-3 lg:py-4 lg:pr-8 lg:pl-8",
      variant === "editorial" && "bg-background sticky top-0 z-30 backdrop-blur-md",
    ]}
  >
    <div class="flex items-center justify-between gap-3">
      <div class="min-w-0">
        <div class="flex items-center gap-2.5">
          <h1 class="truncate text-lg font-semibold tracking-tight md:text-xl">
            {mode === "new" && <LiveHeading client:load initial={`New ${collection.labels.singular}`} />}
            {
              mode === "edit" && (
                <LiveHeading
                  client:load
                  initial={
                    collection.singleton
                      ? collection.labels.singular
                      : String(doc?.[getLabelField(collection)] ?? doc?.slug ?? collection.labels.singular)
                  }
                />
              )
            }
          </h1>
          {mode === "edit" && doc && collection.drafts && <StatusBadge status={getVisualStatus(doc)} styled />}
        </div>
        {
          isSubmissionView && doc && (
            <div class="text-muted-foreground mt-1 flex flex-wrap items-center gap-x-1 text-xs">
              {parentFormTitle && <span>{parentFormTitle}</span>}
              {parentFormTitle && <Dot className="text-muted-foreground/70 size-4" />}
              <span>Submitted {formatDate(String(doc._createdAt ?? ""))}</span>
            </div>
          )
        }
      </div>

      {
        formTab !== "submissions" && (
          <div class="flex flex-shrink-0 flex-wrap items-center justify-end gap-2">
            {hasPreview && previewUrl && !translationMode && (
              <>
                <a href={previewUrl} target="_blank" class={buttonVariants({ variant: "outline" })}>
                  Preview
                  <ArrowUpRight className="size-4" />
                </a>
                <div class="bg-border mx-1 h-6 w-px" />
              </>
            )}
            {locales.length > 1 &&
              mode === "edit" &&
              translatableFields.length > 0 &&
              locales.map((locale) => (
                <a
                  href={`/admin/${collection.slug}/${documentId}?locale=${locale}`}
                  class:list={[
                    buttonVariants({ variant: "outline", size: "sm" }),
                    selectedLocale === locale
                      ? "border-primary/50 bg-background ring-ring/30 font-medium ring-2"
                      : "text-muted-foreground",
                  ]}
                >
                  {locale.toUpperCase()}
                </a>
              ))}
            {translationMode ? (
              <button
                class={buttonVariants({ variant: "outline" })}
                type="submit"
                form="translation-form"
                value="save"
                disabled
              >
                Save translation
              </button>
            ) : (
              <>
                <button
                  class={buttonVariants({ variant: "outline" })}
                  type="submit"
                  form="document-form"
                  name="_intent"
                  value="save"
                  disabled={mode === "edit"}
                >
                  {collection.slug === "users" && mode === "new"
                    ? "Send invite"
                    : collection.drafts
                      ? "Save draft"
                      : "Save"}
                </button>
                {collection.drafts && (
                  <button
                    class={buttonVariants({ variant: "publish" })}
                    type="submit"
                    form="document-form"
                    name="_intent"
                    value="publish"
                    disabled={
                      mode === "edit" &&
                      !(
                        doc?._status === "draft" ||
                        doc?._status === "scheduled" ||
                        (doc && getVisualStatus(doc) === "changed")
                      )
                    }
                  >
                    Publish
                  </button>
                )}
              </>
            )}
            {mode === "edit" && !translationMode && documentId && (
              <DocumentActions
                client:load
                formId="document-form"
                collectionSlug={collection.slug}
                documentId={documentId}
                showUnpublish={collection.drafts && doc?._status === "published"}
                showDiscardDraft={Boolean(collection.drafts && doc?._status === "published" && doc?._published)}
                showDelete={!isSingleton}
                showDuplicate={!isSingleton}
                showSchedule={!!collection.drafts}
                showCancelSchedule={collection.drafts && doc?._status === "scheduled"}
                currentPublishAt={doc?._publishAt ? String(doc._publishAt) : undefined}
                currentUnpublishAt={doc?._unpublishAt ? String(doc._unpublishAt) : undefined}
                versions={versions}
                restoreEndpoint={getFormAction(collection.slug, documentId)}
                redirectTo={Astro.url.pathname + Astro.url.search}
              />
            )}
          </div>
        )
      }
    </div>
  </div>

  {/* Body — everything below the sticky bar, inset from the page edges */}
  <div class="space-y-6 px-4 pb-8 lg:pr-8 lg:pb-12 lg:pl-20">
    {
      formTab !== "submissions" && (
        <>
          {mode === "edit" && documentId && (
            <DocumentLock client:load collection={collection.slug} documentId={documentId} />
          )}
          <UnsavedGuard
            client:load
            formId={translationMode ? "translation-form" : "document-form"}
            isNew={mode === "new"}
            isDraft={Boolean(
              !translationMode &&
              collection.drafts &&
              (doc?._status === "draft" || doc?._status === "scheduled" || (doc && getVisualStatus(doc) === "changed")),
            )}
          />
          <div id="document-edit-area">
            {collection.slug === "users" && mode === "edit" && Astro.url.searchParams.get("inviteToken") && (
              <AdminCard title={Astro.url.searchParams.get("emailSent") === "true" ? "Invitation sent" : "Invite link"}>
                {Astro.url.searchParams.get("emailSent") === "true" ? (
                  <p class="text-muted-foreground text-sm">
                    An invitation email has been sent. The user can also use this link:
                  </p>
                ) : (
                  <p class="text-muted-foreground text-sm">
                    Email is not configured. Share this link with the user to complete their registration:
                  </p>
                )}
                <code class="bg-muted mt-2 block rounded-md px-3 py-2 text-sm break-all select-all">
                  {Astro.url.origin}/admin/invite?token={Astro.url.searchParams.get("inviteToken")}
                </code>
              </AdminCard>
            )}

            {!translationMode && (
              <form
                id="document-form"
                method="post"
                action={getFormAction(collection.slug, mode === "edit" ? documentId : undefined)}
                class:list={[
                  "grid items-start gap-y-10",
                  hasSidebarColumn ? "2xl:grid-cols-[minmax(0,1fr)_minmax(320px,400px)] 2xl:gap-x-20" : "max-w-3xl",
                ]}
              >
                <input type="hidden" name="_action" value={mode === "new" ? "create" : "update"} />
                <input type="hidden" name="redirectTo" value={Astro.url.pathname + Astro.url.search} />

                <div class="min-w-0 space-y-7">
                  {isSubmissionView ? (
                    <AdminCard title="Submission">
                      <table class="w-full text-sm">
                        <tbody>
                          {Object.entries(submittedFields).map(([key, value]) => (
                            <tr class="border-b last:border-b-0">
                              <td class="text-muted-foreground w-1/3 py-2 pr-4 align-top font-medium">{key}</td>
                              <td class="py-2 align-top break-words whitespace-pre-wrap">
                                {formatSubmissionValue(value)}
                              </td>
                            </tr>
                          ))}
                          {submissionContextEntries.map(([key, value]) => (
                            <tr class="border-b last:border-b-0">
                              <td class="text-muted-foreground w-1/3 py-2 pr-4 align-top font-medium">{key}</td>
                              <td class="py-2 align-top break-words whitespace-pre-wrap">
                                {formatSubmissionValue(value)}
                              </td>
                            </tr>
                          ))}
                          {Object.keys(submittedFields).length === 0 && submissionContextEntries.length === 0 && (
                            <tr>
                              <td class="text-muted-foreground py-2" colspan="2">
                                No data.
                              </td>
                            </tr>
                          )}
                        </tbody>
                      </table>
                    </AdminCard>
                  ) : (
                    mainFieldSets.map((set) => {
                      const fields = (
                        <div class:list={["grid", variant === "record" ? "gap-6" : "gap-8"]}>
                          {set.fields
                            .filter((fieldName) => collection.fields[fieldName] && !isFieldHidden(fieldName))
                            .map((fieldName) => (
                              <FieldControl
                                name={fieldName}
                                field={collection.fields[fieldName]}
                                value={getCurrentValue(fieldName)}
                                readOnly={isFieldReadOnly(fieldName)}
                                relationOptions={relationOptionsByField[fieldName] ?? []}
                                relationMeta={relationMetaByField[fieldName]}
                                menuLinkOptions={menuLinkOptions}
                                blockRelationOptions={blockRelationOptions}
                                sharedBlockTypes={sharedBlockTypes}
                                sharedBlockRelationOptions={sharedBlockRelationOptions}
                                sharedSectionOptions={sharedSectionOptions}
                              />
                            ))}
                        </div>
                      );
                      return variant === "record" ? (
                        <AdminCard title={collection.labels.singular}>{fields}</AdminCard>
                      ) : (
                        fields
                      );
                    })
                  )}
                </div>

                {hasSidebarColumn && (
                  <div class="text-sm 2xl:border-l 2xl:pl-8 [&_button]:text-sm [&_input]:text-sm [&_select]:text-sm [&_textarea]:text-sm">
                    <div class="space-y-6">
                      {effectiveSidebarFieldSets.map((set) => {
                        const fields = (
                          <div class="grid gap-6">
                            {set.fields
                              .filter((fieldName) => collection.fields[fieldName] && !isFieldHidden(fieldName))
                              .map((fieldName) => (
                                <div>
                                  <FieldControl
                                    name={fieldName}
                                    field={collection.fields[fieldName]}
                                    value={getCurrentValue(fieldName)}
                                    readOnly={isFieldReadOnly(fieldName)}
                                    relationOptions={relationOptionsByField[fieldName] ?? []}
                                    relationMeta={relationMetaByField[fieldName]}
                                    menuLinkOptions={menuLinkOptions}
                                    blockRelationOptions={blockRelationOptions}
                                    sharedBlockTypes={sharedBlockTypes}
                                    sharedBlockRelationOptions={sharedBlockRelationOptions}
                                    sharedSectionOptions={sharedSectionOptions}
                                  />
                                  {aiEnabled && fieldName === "seoDescription" && !isFieldReadOnly(fieldName) && (
                                    <div class="mt-1.5">
                                      <AiGenerateButton
                                        client:load
                                        endpoint="/api/cms/ai/seo"
                                        payload={{
                                          title: getCurrentValue("title") ?? "",
                                          excerpt: getCurrentValue("excerpt") ?? "",
                                        }}
                                        targetField={fieldName}
                                        label="Generate description"
                                      />
                                    </div>
                                  )}
                                </div>
                              ))}
                          </div>
                        );
                        return variant === "record" ? <AdminCard title="Settings">{fields}</AdminCard> : fields;
                      })}
                      {hasSidebarMeta && (
                        <div
                          class:list={[
                            variant === "record" ? "space-y-6" : "grid gap-6",
                            variant !== "record" && hasSidebarFields && "border-t pt-6",
                          ]}
                        >
                          <ReverseReferencesList reverseRefs={reverseRefs} variant={variant} />
                          {hasDocMeta &&
                            doc &&
                            (() => {
                              const meta = (
                                <dl class="text-muted-foreground grid gap-1 text-xs">
                                  {doc._status === "scheduled" && doc._publishAt && (
                                    <>
                                      <div class="flex justify-between gap-2">
                                        <dt>Publishes</dt>
                                        <dd class="text-foreground/70">{formatDate(doc._publishAt)}</dd>
                                      </div>
                                      {doc._unpublishAt && (
                                        <div class="flex justify-between gap-2">
                                          <dt>Unpublishes</dt>
                                          <dd class="text-foreground/70">{formatDate(doc._unpublishAt)}</dd>
                                        </div>
                                      )}
                                    </>
                                  )}
                                  <div class="flex justify-between gap-2">
                                    <dt>Created</dt>
                                    <dd class="text-foreground/70">{formatDate(doc._createdAt)}</dd>
                                  </div>
                                  <div class="flex justify-between gap-2">
                                    <dt>Updated</dt>
                                    <dd class="text-foreground/70">{formatDate(doc._updatedAt)}</dd>
                                  </div>
                                </dl>
                              );

                              return variant === "record" ? (
                                <AdminCard title="Info">{meta}</AdminCard>
                              ) : (
                                <div class:list={["grid gap-2", reverseRefs.length > 0 && "border-t pt-6"]}>
                                  <span class="text-foreground/80 text-sm leading-none font-medium">Info</span>
                                  {meta}
                                </div>
                              );
                            })()}
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </form>
            )}

            {translationMode && (
              <div class="space-y-6">
                <form
                  id="translation-form"
                  method="post"
                  action={getFormAction(collection.slug, documentId)}
                  class="max-w-3xl"
                >
                  <input type="hidden" name="_action" value="save-translation" />
                  <input type="hidden" name="locale" value={selectedLocale} />
                  <input type="hidden" name="redirectTo" value={Astro.url.pathname + Astro.url.search} />

                  <div class="grid gap-7">
                    {translatableFields
                      .filter((fn) => !isFieldHidden(fn))
                      .map((fieldName) => {
                        const fieldDef = collection.fields[fieldName];
                        const fieldType =
                          fieldDef.type === "richText" ? "richText" : fieldDef.type === "slug" ? "slug" : "text";
                        const sourceValue = getSharedValue(fieldName);
                        const sourceText =
                          typeof sourceValue === "object" && sourceValue !== null
                            ? JSON.stringify(sourceValue)
                            : String(sourceValue ?? "");
                        return (
                          <div>
                            <FieldControl
                              name={fieldName}
                              field={fieldDef}
                              value={getCurrentValue(fieldName)}
                              readOnly={isFieldReadOnly(fieldName)}
                              relationOptions={relationOptionsByField[fieldName] ?? []}
                              relationMeta={relationMetaByField[fieldName]}
                              menuLinkOptions={menuLinkOptions}
                              blockRelationOptions={blockRelationOptions}
                              sharedBlockTypes={sharedBlockTypes}
                              sharedBlockRelationOptions={sharedBlockRelationOptions}
                              sharedSectionOptions={sharedSectionOptions}
                            />
                            {aiEnabled &&
                              sourceText &&
                              fieldDef.type !== "slug" &&
                              fieldDef.type !== "blocks" &&
                              fieldDef.type !== "content" && (
                                <div class="mt-1.5">
                                  <AiGenerateButton
                                    client:load
                                    endpoint="/api/cms/ai/translate"
                                    payload={{
                                      text: sourceText,
                                      sourceLocale: defaultLocale,
                                      targetLocale: selectedLocale,
                                      fieldName,
                                      fieldType,
                                    }}
                                    targetField={fieldName}
                                    label={`Translate from ${defaultLocale.toUpperCase()}`}
                                  />
                                </div>
                              )}
                          </div>
                        );
                      })}
                  </div>
                </form>
              </div>
            )}
          </div>
        </>
      )
    }
  </div>
</section>

<EditScripts />
