---
import "virtual:kide/admin-css";
import { cms } from "virtual:kide/api";

import {
  Clock,
  FileText,
  FolderTree,
  Image,
  Layers,
  LayoutGrid,
  Menu,
  PencilRuler,
  Plus,
  Users,
  BarChart,
  Bell,
  Bookmark,
  Calendar,
  Database,
  Globe,
  Home,
  Key,
  Link,
  Lock,
  Mail,
  MessageSquare,
  Package,
  Palette,
  Search,
  Settings,
  Shield,
  Star,
  Tag,
  Terminal,
  Zap,
} from "lucide-react";

const navIconMap: Record<string, any> = {
  BarChart,
  Bell,
  Bookmark,
  Calendar,
  Clock,
  Database,
  FileText,
  FolderTree,
  Globe,
  Home,
  Image,
  Key,
  Layers,
  LayoutGrid,
  Link,
  Lock,
  Mail,
  Menu,
  MessageSquare,
  Package,
  Palette,
  PencilRuler,
  Search,
  Settings,
  Shield,
  Star,
  Tag,
  Terminal,
  Users,
  Zap,
};

import CommandPalette from "../components/CommandPalette";
import MobileSidebar from "../components/MobileSidebar";
import SidebarUserMenu from "../components/SidebarUserMenu";
import Toast from "../components/Toast.astro";
import { cn } from "../lib/utils";

const {
  title = "Admin",
  collections = [],
  activeCollection = null,
  embed = false,
  customNav = [],
} = Astro.props as {
  title?: string;
  collections?: Array<{ slug: string; labels: { singular: string; plural: string }; singleton?: boolean }>;
  activeCollection?: string | null;
  embed?: boolean;
  customNav?: Array<{ label: string; href: string; icon?: string; weight?: number }>;
};

const user = Astro.locals.user;

// Server-side toast: read _toast/_msg params set by API redirect
const toastStatus = Astro.url.searchParams.get("_toast") as "success" | "error" | null;
const toastMessage =
  Astro.url.searchParams.get("_msg") ?? (toastStatus === "success" ? "Saved successfully" : "Something went wrong");

// Build sidebar nav in explicit order:
// 1. Content collections (alphabetical, shared icon)
// 2. Singles
// 3. Taxonomies, Menus, Forms, Authors, Users (pinned utility collections)
// 4. Assets

const pinnedOrder = ["taxonomies", "menus", "forms", "authors", "users"];
const pinnedSlugs = new Set(pinnedOrder);
const pinnedIcons: Record<string, any> = {
  taxonomies: FolderTree,
  menus: Menu,
  forms: MessageSquare,
  authors: PencilRuler,
  users: Users,
};

// Unread submissions badge — shown next to "Forms" in the sidebar.
let unreadSubmissions = 0;
try {
  const cmsAny = cms as Record<string, any>;
  if (cmsAny["form-submissions"]) {
    unreadSubmissions = await cmsAny["form-submissions"].count({ where: { status: "new" } }, { _system: true });
  }
} catch {
  // Table may not exist yet on first run — ignore.
}

// Collections that should never appear as a top-level sidebar entry.
// Submissions are viewed as a tab on the parent form's detail page.
const hiddenFromSidebar = new Set(["form-submissions"]);

const hasSingletons = collections.some((c) => c.singleton);
const singletonSlugs = new Set(collections.filter((c) => c.singleton).map((c) => c.slug));
const isActiveSingles =
  activeCollection === "singles" || (activeCollection !== null && singletonSlugs.has(activeCollection));

type NavItem = {
  href: string;
  label: string;
  singularLabel?: string;
  Icon: any;
  active: boolean;
  newHref?: string;
  weight: number;
  badge?: number;
};
const navItems: NavItem[] = [];

// Built-in nav items with default weights (spaced by 10 for easy interleaving)
navItems.push({
  href: "/admin/recent",
  label: "Recent",
  Icon: Clock,
  active: activeCollection === "recent",
  weight: 0,
});

const contentCollections = collections
  .filter((c) => !c.singleton && !pinnedSlugs.has(c.slug) && !hiddenFromSidebar.has(c.slug))
  .sort((a, b) => a.labels.plural.localeCompare(b.labels.plural));
for (const c of contentCollections) {
  navItems.push({
    href: `/admin/${c.slug}`,
    label: c.labels.plural,
    singularLabel: c.labels.singular,
    Icon: Layers,
    active: activeCollection === c.slug,
    newHref: `/admin/${c.slug}/new`,
    weight: 10,
  });
}

if (hasSingletons) {
  navItems.push({ href: "/admin/singles", label: "Singles", Icon: FileText, active: isActiveSingles, weight: 20 });
}

for (const slug of pinnedOrder) {
  const c = collections.find((col) => col.slug === slug);
  if (c) {
    navItems.push({
      href: `/admin/${c.slug}`,
      label: c.labels.plural,
      singularLabel: c.labels.singular,
      Icon: pinnedIcons[slug] ?? LayoutGrid,
      active: activeCollection === c.slug,
      newHref: `/admin/${c.slug}/new`,
      weight: 30,
      badge: slug === "forms" && unreadSubmissions > 0 ? unreadSubmissions : undefined,
    });
  }
}

navItems.push({
  href: "/admin/assets",
  label: "Assets",
  Icon: Image,
  active: activeCollection === "assets",
  weight: 40,
});

// Custom nav items from admin config
const currentPath = Astro.url.pathname;
for (const item of customNav) {
  navItems.push({
    href: item.href,
    label: item.label,
    Icon: navIconMap[item.icon ?? ""] ?? LayoutGrid,
    active: currentPath === item.href || currentPath.startsWith(item.href + "/"),
    weight: item.weight ?? 50,
  });
}

// Sort all items by weight (stable sort preserves order within same weight)
navItems.sort((a, b) => a.weight - b.weight);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <script is:inline>
      if (!document.cookie.includes("tz="))
        document.cookie = "tz=" + Intl.DateTimeFormat().resolvedOptions().timeZone + ";path=/;max-age=31536000";
    </script>
    <script is:inline>
      (function () {
        var t = localStorage.getItem("admin-theme") || "system";
        var dark = t === "dark" || (t === "system" && matchMedia("(prefers-color-scheme: dark)").matches);
        if (dark) document.documentElement.classList.add("dark");
      })();
    </script>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <CommandPalette client:load />
    {
      embed ? (
        <main class="mx-auto w-full px-4 py-6 lg:px-8 lg:py-8">
          <slot />
        </main>
      ) : (
        <div
          class="min-h-screen lg:grid"
          style="grid-template-columns: 17rem 1fr; transition: grid-template-columns 150ms ease;"
        >
          {/* ── Desktop sidebar ──────────────────────────────────────────── */}
          <aside class="bg-sidebar/40 sticky top-0 mt-1 hidden h-screen overflow-hidden border-r backdrop-blur transition-transform duration-150 ease-in-out lg:flex lg:flex-col">
            <div class="px-3 pt-4 pb-1">
              <button
                type="button"
                data-cms-search-trigger
                class="bg-background/60 hover:bg-background border-input text-muted-foreground hover:text-foreground/90 flex w-full items-center gap-2 rounded-md border px-3 py-2 text-sm transition-colors hover:cursor-text"
                aria-label="Search content"
              >
                <Search className="size-4 shrink-0 stroke-1" />
                <span class="flex-1 text-left">Search…</span>
                <kbd
                  data-cms-search-kbd
                  class="border-border text-foreground/45 inline-flex items-center gap-1 rounded border px-1.5 py-0.5 font-sans text-[12px] leading-none font-medium"
                >
                  <span class="text-[13px] leading-none">⌘</span>
                  <span>K</span>
                </kbd>
              </button>
            </div>

            <nav class="flex-1 space-y-1 overflow-y-auto px-3 py-3">
              {navItems.map((item) => (
                <div
                  class={cn(
                    "group relative rounded-lg",
                    item.active ? "bg-foreground/10 dark:bg-accent" : "hover:bg-foreground/5 dark:hover:bg-accent/60",
                  )}
                >
                  <a
                    href={item.href}
                    class={cn(
                      "flex items-center gap-3 px-3 py-2.5 text-sm",
                      item.newHref && "pr-8",
                      item.active ? "text-accent-foreground" : "text-foreground/70 group-hover:text-foreground",
                    )}
                  >
                    <item.Icon className="size-4 shrink-0 stroke-1" />
                    <span class="flex-1">{item.label}</span>
                    {item.badge ? (
                      <span class="text-muted-foreground/80 text-xs tabular-nums">
                        {item.badge > 99 ? "99+" : item.badge} new
                      </span>
                    ) : null}
                  </a>
                  {item.newHref && (
                    <a
                      href={item.newHref}
                      title={`Add new ${(item.singularLabel ?? item.label).toLowerCase()}`}
                      class="text-foreground/40 hover:text-foreground/70 absolute top-1/2 right-1.5 hidden -translate-y-1/2 rounded p-1 group-hover:block"
                    >
                      <Plus className="size-3.5" />
                    </a>
                  )}
                </div>
              ))}
            </nav>
            <div class="border-t px-3 pt-2 pb-2">
              {user && (
                <SidebarUserMenu
                  client:load
                  userName={user.name}
                  userEmail={user.email}
                  logoutAction="/api/cms/auth/logout"
                />
              )}
            </div>
          </aside>

          <div class="min-w-0">
            {/* ── Mobile header ────────────────────────────────────────── */}
            <header class="bg-background/95 supports-backdrop-filter:bg-background/75 flex items-center gap-3 border-b px-4 py-3 backdrop-blur lg:hidden">
              <MobileSidebar client:load>
                <div class="px-3 pt-4 pb-1">
                  <button
                    type="button"
                    data-cms-search-trigger
                    class="bg-background/60 hover:bg-background border-input text-muted-foreground hover:text-foreground flex w-full items-center gap-2 rounded-md border px-3 py-2 text-sm transition-colors"
                    aria-label="Search content"
                  >
                    <Search className="size-4 shrink-0 stroke-1" />
                    <span class="flex-1 text-left">Search…</span>
                  </button>
                </div>

                <nav class="flex-1 space-y-1 overflow-y-auto px-3 py-3">
                  {navItems.map((item) => (
                    <div
                      class={cn(
                        "group relative rounded-lg",
                        item.active
                          ? "bg-foreground/10 dark:bg-accent"
                          : "hover:bg-foreground/5 dark:hover:bg-accent/60",
                      )}
                    >
                      <a
                        href={item.href}
                        class={cn(
                          "flex items-center gap-3 px-3 py-2.5 text-sm",
                          item.newHref && "pr-8",
                          item.active ? "text-accent-foreground" : "text-foreground/70 group-hover:text-foreground",
                        )}
                      >
                        <item.Icon className="size-4 shrink-0 stroke-1" />
                        <span class="flex-1">{item.label}</span>
                        {item.badge ? (
                          <span class="text-muted-foreground/80 text-xs tabular-nums">
                            {item.badge > 99 ? "99+" : item.badge} new
                          </span>
                        ) : null}
                      </a>
                      {item.newHref && (
                        <a
                          href={item.newHref}
                          title={`Add new ${(item.singularLabel ?? item.label).toLowerCase()}`}
                          class="text-foreground/40 hover:text-foreground/70 absolute top-1/2 right-1.5 hidden -translate-y-1/2 rounded p-1 group-hover:block"
                        >
                          <Plus className="size-3.5" />
                        </a>
                      )}
                    </div>
                  ))}
                </nav>
                <div class="border-t px-3 py-2">
                  {user && (
                    <SidebarUserMenu
                      client:load
                      userName={user.name}
                      userEmail={user.email}
                      logoutAction="/api/cms/auth/logout"
                    />
                  )}
                </div>
              </MobileSidebar>
            </header>

            <main class="mx-auto w-full max-w-[1900px] px-4 py-6 lg:px-8 lg:py-8">
              <slot />
            </main>
          </div>
        </div>
      )
    }

    {toastStatus && <Toast status={toastStatus} message={toastMessage} />}

    {/* Wire sidebar search triggers to the CommandPalette */}
    <script is:inline>
      (function () {
        document.addEventListener("click", function (e) {
          var t = e.target instanceof Element ? e.target.closest("[data-cms-search-trigger]") : null;
          if (t) window.dispatchEvent(new Event("cms:open-search"));
        });
        var isMac = /Mac|iPhone|iPad|iPod/i.test(navigator.userAgent || "");
        if (!isMac) {
          document.querySelectorAll("[data-cms-search-kbd]").forEach(function (el) {
            el.textContent = "Ctrl+K";
          });
        }
      })();
    </script>

    {/* Clean toast params from URL and remove toast element after animation */}
    <script is:inline>
      (function () {
        var p = new URLSearchParams(location.search);
        var status = p.get("_toast");
        if (!status) return;
        p.delete("_toast");
        p.delete("_msg");
        history.replaceState({}, "", location.pathname + (p.size ? "?" + p : ""));
        // Error toasts stay longer (5s) than success toasts (3s)
        var delay = status === "error" ? 5200 : 3200;
        setTimeout(function () {
          var el = document.getElementById("admin-toast");
          if (el) el.remove();
        }, delay);
      })();
    </script>
  </body>
</html>
