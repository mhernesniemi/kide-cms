---
import "virtual:kide/admin-css";

import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/cms/admin/components/ui/card";
import { Input } from "@/cms/admin/components/ui/input";
import { Label } from "@/cms/admin/components/ui/label";
import { buttonVariants } from "@/cms/admin/components/ui/button";
import { resolveAdminAuth } from "@/cms/core";
import config from "virtual:kide/config";

export const prerender = false;

const auth = resolveAdminAuth(config);
if (!auth.password.forgotPassword) return Astro.redirect("/admin/login");

const status = Astro.url.searchParams.get("status");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Reset password | Kide CMS</title>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <div class="flex min-h-screen items-center justify-center px-4">
      <div class="w-full max-w-sm space-y-6">
        <h1 class="text-center text-xl font-semibold tracking-tight">Kide CMS</h1>
        <Card>
          <CardHeader>
            <CardTitle>Reset password</CardTitle>
            <CardDescription>Enter your email and we'll send a reset link</CardDescription>
          </CardHeader>
          <CardContent>
            {
              status === "sent" && (
                <div class="border-border bg-muted mb-4 rounded-lg border px-3 py-2 text-sm">
                  If that account exists, a reset link has been sent.
                </div>
              )
            }
            <form method="post" action="/api/cms/auth/forgot-password" class="grid gap-4">
              <div class="grid gap-2">
                <Label htmlFor="email">Email</Label>
                <Input id="email" name="email" type="email" placeholder="admin@example.com" required autoFocus />
              </div>
              <button class={buttonVariants({ size: "lg", className: "w-full" })} type="submit">Send reset link</button>
              <a class="text-muted-foreground hover:text-foreground text-center text-sm" href="/admin/login">
                Back to sign in
              </a>
            </form>
          </CardContent>
        </Card>
      </div>
    </div>
  </body>
</html>
