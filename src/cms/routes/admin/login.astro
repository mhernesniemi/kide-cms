---
import "virtual:kide/admin-css";

import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/cms/admin/components/ui/card";
import { Input } from "@/cms/admin/components/ui/input";
import { Label } from "@/cms/admin/components/ui/label";
import { buttonVariants } from "@/cms/admin/components/ui/button";
import { resolveAdminAuth } from "@/cms/core";
import config from "virtual:kide/config";

export const prerender = false;

const error = Astro.url.searchParams.get("error");
const errorMessage =
  error === "invalid"
    ? "Invalid email or password."
    : error === "missing"
      ? "Email and password are required."
      : error === "disabled"
        ? "Password login is disabled."
        : null;
const auth = resolveAdminAuth(config);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Sign in | Kide CMS</title>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <div class="flex min-h-screen items-center justify-center px-4">
      <div class="w-full max-w-sm space-y-6">
        <h1 class="text-center text-xl font-semibold tracking-tight">Kide CMS</h1>
        <Card>
          <CardHeader>
            <CardTitle>Sign in</CardTitle>
            <CardDescription>Enter your credentials to continue</CardDescription>
          </CardHeader>
          <CardContent>
            {
              errorMessage && (
                <div class="border-destructive/50 bg-destructive/10 text-destructive mb-4 rounded-lg border px-3 py-2 text-sm">
                  {errorMessage}
                </div>
              )
            }
            <form method="post" action="/api/cms/auth/login" class="grid gap-4">
              {
                auth.password.enabled && (
                  <>
                    <div class="grid gap-2">
                      <Label htmlFor="email">Email</Label>
                      <Input id="email" name="email" type="email" placeholder="admin@example.com" required autoFocus />
                    </div>
                    <div class="grid gap-2">
                      <div class="flex items-center justify-between gap-3">
                        <Label htmlFor="password">Password</Label>
                        {auth.password.forgotPassword && (
                          <a class="text-muted-foreground hover:text-foreground text-xs" href="/admin/forgot-password">
                            Forgot password?
                          </a>
                        )}
                      </div>
                      <Input id="password" name="password" type="password" placeholder="Enter password" required />
                    </div>
                    <button class={buttonVariants({ size: "lg", className: "w-full" })} type="submit">
                      Sign in
                    </button>
                  </>
                )
              }
            </form>
            {
              auth.ssoProviders.length > 0 && (
                <div class="mt-4 grid gap-3">
                  {auth.password.enabled && (
                    <div class="text-muted-foreground flex items-center gap-3 text-xs">
                      <div class="bg-border h-px flex-1" />
                      <span>or</span>
                      <div class="bg-border h-px flex-1" />
                    </div>
                  )}
                  {auth.ssoProviders.map((provider) => (
                    <a
                      class={buttonVariants({ variant: "outline", size: "lg", className: "w-full" })}
                      href={`/api/cms/auth/sso/${provider.id}/start`}
                    >
                      Continue with {provider.label}
                    </a>
                  ))}
                </div>
              )
            }
          </CardContent>
        </Card>
      </div>
    </div>
  </body>
</html>
