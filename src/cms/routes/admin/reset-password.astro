---
import "virtual:kide/admin-css";

import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/cms/admin/components/ui/card";
import { Input } from "@/cms/admin/components/ui/input";
import { Label } from "@/cms/admin/components/ui/label";
import { buttonVariants } from "@/cms/admin/components/ui/button";
import { resolveAdminAuth } from "@/cms/core";
import config from "virtual:kide/config";

export const prerender = false;

const auth = resolveAdminAuth(config);
if (!auth.password.forgotPassword) return Astro.redirect("/admin/login");

const token = Astro.url.searchParams.get("token") ?? "";
const error = Astro.url.searchParams.get("error");
const errorMessage =
  error === "missing"
    ? "Password is required."
    : error === "password"
      ? "Passwords do not match."
      : error === "short"
        ? "Password must be at least 8 characters."
        : error === "invalid"
          ? "This reset link is invalid or expired."
          : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Choose new password | Kide CMS</title>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <div class="flex min-h-screen items-center justify-center px-4">
      <div class="w-full max-w-sm space-y-6">
        <h1 class="text-center text-xl font-semibold tracking-tight">Kide CMS</h1>
        <Card>
          <CardHeader>
            <CardTitle>Choose new password</CardTitle>
            <CardDescription>Set a new password for your account</CardDescription>
          </CardHeader>
          <CardContent>
            {
              errorMessage && (
                <div class="border-destructive/50 bg-destructive/10 text-destructive mb-4 rounded-lg border px-3 py-2 text-sm">
                  {errorMessage}
                </div>
              )
            }
            <form method="post" action="/api/cms/auth/reset-password" class="grid gap-4">
              <input type="hidden" name="token" value={token} />
              <div class="grid gap-2">
                <Label htmlFor="password">New password</Label>
                <Input id="password" name="password" type="password" required autoFocus />
              </div>
              <div class="grid gap-2">
                <Label htmlFor="confirmPassword">Confirm password</Label>
                <Input id="confirmPassword" name="confirmPassword" type="password" required />
              </div>
              <button class={buttonVariants({ size: "lg", className: "w-full" })} type="submit">Reset password</button>
            </form>
          </CardContent>
        </Card>
      </div>
    </div>
  </body>
</html>
