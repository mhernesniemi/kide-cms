---
import AdminLayout from "@/cms/admin/layouts/AdminLayout.astro";
import AccessDeniedView from "@/cms/admin/views/AccessDeniedView.astro";
import EditView from "@/cms/admin/views/EditView.astro";
import ListView from "@/cms/admin/views/ListView.astro";
import RecentView from "@/cms/admin/views/RecentView.astro";
import SinglesView from "@/cms/admin/views/SinglesView.astro";
import config from "virtual:kide/config";
import { cms } from "virtual:kide/api";
import { initDateFormat, resolveAdminRoute } from "@/cms/core";
import { canRead } from "@/cms/admin/lib/access";

export const prerender = false;

initDateFormat(config, Astro.cookies.get("tz")?.value);

const route = resolveAdminRoute(Astro.params.path);
const user = Astro.locals.user;
const runtimeContext = user ? { user: { id: user.id, role: user.role, email: user.email } } : {};
const isEmbed = Astro.url.searchParams.get("_embed") === "1";
const accessibleCollections = config.collections.filter((c) => canRead(config, user, c.slug));

// /admin → /admin/recent
if (route.kind === "dashboard") return Astro.redirect("/admin/recent");

const collectionSlug = "collectionSlug" in route ? route.collectionSlug : null;
const collection = collectionSlug ? (cms.meta.getCollection(collectionSlug) as any) : null;
const canAccessCurrent =
  route.kind === "recent" || route.kind === "singles" || !collectionSlug || canRead(config, user, collectionSlug);

// Singletons: redirect list/new to the single document's edit page
if (collection?.singleton && canAccessCurrent && (route.kind === "list" || route.kind === "new")) {
  const cmsRuntime = cms as Record<string, any>;
  const collectionApi = cmsRuntime[collection.slug];
  const singleDocs = await collectionApi.find({ status: "any", limit: 1 }, runtimeContext);
  const singletonId = (singleDocs[0] ?? (await collectionApi.create({}, runtimeContext)))._id;
  return Astro.redirect(`/admin/${collection.slug}/${singletonId}`);
}

const title =
  route.kind === "recent"
    ? "Recent | Kide CMS"
    : route.kind === "singles"
      ? "Singles | Kide CMS"
      : `${collection?.labels?.plural ?? "Admin"} | Kide CMS`;

const activeCollection = route.kind === "recent" ? "recent" : (collectionSlug ?? "singles");
---

<AdminLayout
  title={title}
  collections={accessibleCollections}
  activeCollection={activeCollection}
  embed={isEmbed}
  customNav={config.admin?.nav}
>
  {route.kind === "recent" && <RecentView />}
  {route.kind === "singles" && <SinglesView />}
  {route.kind !== "recent" && route.kind !== "singles" && !canAccessCurrent && <AccessDeniedView />}
  {route.kind === "list" && canAccessCurrent && collection && <ListView collection={collection} />}
  {
    (route.kind === "new" || route.kind === "edit") && canAccessCurrent && collection && (
      <EditView
        collection={collection}
        mode={route.kind}
        documentId={route.kind === "edit" ? route.documentId : undefined}
      />
    )
  }
</AdminLayout>
