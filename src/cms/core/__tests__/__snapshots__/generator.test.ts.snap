    publish(id: string, context?: { user?: { id: string; role?: string; email?: string; [key: string]: unknown } | null }): Promise<ArticlesDocument>;
    unpublish(id: string, context?: { user?: { id: string; role?: string; email?: string; [key: string]: unknown } | null }): Promise<ArticlesDocument>;
    schedule(id: string, publishAt: string, unpublishAt?: string | null, context?: { user?: { id: string; role?: string; email?: string; [key: string]: unknown } | null }): Promise<ArticlesDocument>;
    getTranslations(id: string): Promise<Record<string, ArticlesTranslationInput>>;
    upsertTranslation(id: string, locale: string, data: ArticlesTranslationInput, context?: { user?: { id: string; role?: string; email?: string; [key: string]: unknown } | null }): Promise<ArticlesDocument>;
  };
