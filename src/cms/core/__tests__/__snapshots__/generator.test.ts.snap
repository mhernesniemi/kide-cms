"// auto-generated — do not edit
import { z } from "zod";

export const ArticlesCreateSchema = z.object({
  title: z.string(),
  slug: z.string().optional(),
  readingTime: z.number().optional(),
  featured: z.boolean().optional(),
  publishDate: z.string().optional(),
  tone: z.enum(["formal", "casual"]).optional(),
  body: z.object({ type: z.literal('root'), children: z.array(z.any()) }).optional(),
  cover: z.string().optional(),
  author: z.string().optional(),
  related: z.array(z.string()).optional(),
  tags: z.array(z.string()).optional(),
  meta: z.record(z.unknown()).optional(),
  article: z.object({ type: z.literal('root'), children: z.array(z.any()) }).optional(),
  sections: z.array(z.discriminatedUnion("type", [
    z.object({ type: z.literal("__shared"), ref: z.string(), title: z.string().optional(), blockType: z.string().optional() }),
    z.object({ type: z.literal("hero"), heading: z.string(), image: z.string().optional() }),
    z.object({ type: z.literal("quote"), text: z.string().optional(), attribution: z.string().optional() }),
  ])).optional(),
});

export const ArticlesUpdateSchema = z.object({
  title: z.string().optional(),
  slug: z.string().optional(),
  readingTime: z.number().optional(),
  featured: z.boolean().optional(),
  publishDate: z.string().optional(),
  tone: z.enum(["formal", "casual"]).optional(),
  body: z.object({ type: z.literal('root'), children: z.array(z.any()) }).optional(),
  cover: z.string().optional(),
  author: z.string().optional(),
  related: z.array(z.string()).optional(),
  tags: z.array(z.string()).optional(),
  meta: z.record(z.unknown()).optional(),
  article: z.object({ type: z.literal('root'), children: z.array(z.any()) }).optional(),
  sections: z.array(z.discriminatedUnion("type", [
    z.object({ type: z.literal("__shared"), ref: z.string(), title: z.string().optional(), blockType: z.string().optional() }),
    z.object({ type: z.literal("hero"), heading: z.string(), image: z.string().optional() }),
    z.object({ type: z.literal("quote"), text: z.string().optional(), attribution: z.string().optional() }),
  ])).optional(),
});

export const WritersCreateSchema = z.object({
  name: z.string(),
  contactEmail: z.string().email().optional(),
});

export const WritersUpdateSchema = z.object({
  name: z.string().optional(),
  contactEmail: z.string().email().optional(),
});

export const validators = {
  "articles": { create: ArticlesCreateSchema, update: ArticlesUpdateSchema },
  "writers": { create: WritersCreateSchema, update: WritersUpdateSchema },
};"
`;
