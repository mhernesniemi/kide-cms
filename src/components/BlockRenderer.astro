---
import { cms } from "@/cms/.generated/api";
import { SHARED_BLOCK_TYPE, isSharedBlockReference } from "@/cms/core";

const { blocks = [], status = "published" } = Astro.props as {
  blocks?: Array<Record<string, unknown>>;
  status?: "published" | "any";
};

// Discover custom block components from src/components/blocks/
const customComponents = import.meta.glob<{ default: any }>("./blocks/*.astro", { eager: true });

// Build a map: block type name → Astro component
const componentMap: Record<string, any> = {};
for (const [path, mod] of Object.entries(customComponents)) {
  // ./blocks/Hero.astro → hero
  const filename = path.split("/").pop()?.replace(".astro", "") ?? "";
  const typeName = filename.charAt(0).toLowerCase() + filename.slice(1);
  componentMap[typeName] = mod.default;
}

const cmsRuntime = cms as Record<string, any>;
const resolvedBlocks: Array<Record<string, unknown>> = [];
for (const block of blocks) {
  if (!isSharedBlockReference(block)) {
    resolvedBlocks.push(block);
    continue;
  }

  const shared = await cmsRuntime["shared-sections"]?.findById(block.ref, { status });
  const sharedBlock = shared?.block;
  if (sharedBlock && typeof sharedBlock === "object") {
    resolvedBlocks.push({
      ...(sharedBlock as Record<string, unknown>),
      _sharedSection: {
        id: block.ref,
        title: shared.title,
      },
    });
  } else if (status === "any") {
    resolvedBlocks.push({
      type: SHARED_BLOCK_TYPE,
      ref: block.ref,
      title: block.title ?? "Missing shared section",
    });
  }
}
---

<div class="flex flex-col gap-16">
  {
    resolvedBlocks.map((block) => {
      const type = String(block.type ?? "");
      if (type === SHARED_BLOCK_TYPE) {
        return (
          <div class="rounded-lg border border-dashed border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            Shared section is unavailable.
          </div>
        );
      }
      const Component = componentMap[type];

      if (!Component) {
        throw new Error(
          `No block component found for type "${type}". Add src/components/blocks/${type.charAt(0).toUpperCase() + type.slice(1)}.astro`,
        );
      }

      return <Component {...block} />;
    })
  }
</div>
