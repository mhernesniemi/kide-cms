---
import RichTextContent from "./RichTextContent.astro";

const { blocks = [] } = Astro.props as { blocks?: Array<Record<string, unknown>> };

function parseArray(val: unknown): any[] {
  if (Array.isArray(val)) return val;
  if (typeof val === "string") {
    try {
      const p = JSON.parse(val);
      return Array.isArray(p) ? p : [];
    } catch {
      return [];
    }
  }
  return [];
}
---

{
  blocks.map((block) => {
    if (block.type === "hero") {
      return (
        <section style="background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem 2rem; margin: 1.5rem 0;">
          {block.eyebrow && (
            <p style="color: #0f766e; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0.25rem;">
              {block.eyebrow}
            </p>
          )}
          <h2 style="font-size: 1.5rem; font-weight: 700; margin: 0 0 0.5rem;">{block.heading}</h2>
          {block.body && <p style="color: #666; margin: 0 0 1rem;">{block.body}</p>}
          {block.ctaLabel && block.ctaHref && (
            <a
              href={String(block.ctaHref)}
              style="display: inline-block; background: #0f766e; color: white; padding: 0.4rem 1rem; border-radius: 0.375rem; text-decoration: none; font-size: 0.85rem;"
            >
              {block.ctaLabel}
            </a>
          )}
        </section>
      );
    }

    if (block.type === "text") {
      return (
        <section style="padding: 2rem 0;">
          {block.heading && <h2 style="font-size: 1.25rem; font-weight: 600; margin: 0 0 0.75rem;">{block.heading}</h2>}
          {block.content && <RichTextContent content={block.content} />}
        </section>
      );
    }

    if (block.type === "gallery") {
      const images = parseArray(block.images);
      if (!images.length) return null;
      return (
        <section style="padding: 2rem 0;">
          <div style="display: grid; gap: 1rem;">
            {images.map((src: string) => (
              <img src={src} alt="" style="width: 100%; border-radius: 0.5rem; object-fit: cover;" />
            ))}
          </div>
        </section>
      );
    }

    if (block.type === "featuredPosts") {
      return (
        <section style="padding: 2rem 0;">
          {block.heading && <h2 style="font-size: 1.25rem; font-weight: 600; margin: 0 0 0.75rem;">{block.heading}</h2>}
          {/* Posts are rendered by ID — requires fetching in the page, not the component */}
        </section>
      );
    }

    if (block.type === "faq") {
      const items = parseArray(block.items);
      return (
        <section style="padding: 2rem 0;">
          {block.heading && <h2 style="font-size: 1.25rem; font-weight: 600; margin: 0 0 1rem;">{block.heading}</h2>}
          {items.length > 0 && (
            <div style="display: grid; gap: 0.75rem;">
              {items.map((item: any) => (
                <div style="background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 1rem 1.25rem;">
                  {item.title && <p style="font-weight: 600; margin: 0 0 0.25rem;">{item.title}</p>}
                  {item.description && <p style="color: #666; margin: 0;">{item.description}</p>}
                </div>
              ))}
            </div>
          )}
        </section>
      );
    }

    return null;
  })
}
