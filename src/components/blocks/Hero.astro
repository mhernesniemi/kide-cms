---
const { eyebrow, heading, body, ctaLabel, ctaHref } = Astro.props;
---

<section class="my-6 rounded-xl border border-gray-200 bg-gray-50 px-8 py-6">
  {eyebrow && <p class="mb-1 text-xs font-semibold tracking-wide text-teal-700 uppercase">{eyebrow}</p>}
  <h2 class="mb-2 text-2xl font-bold">{heading}</h2>
  {body && <p class="mb-4 text-gray-500">{body}</p>}
  {
    ctaLabel && ctaHref && (
      <a href={ctaHref} class="inline-block rounded-md bg-teal-700 px-4 py-2 text-sm text-white no-underline">
        {ctaLabel}
      </a>
    )
  }
</section>
