---
import { parseList } from "@/cms/core";
import CmsPicture from "@/components/CmsPicture.astro";

const { image, caption, images } = Astro.props as { image?: string; caption?: string; images?: unknown };
// `image` is the current single-image shape; fall back to the first of the legacy `images` array.
const src = image || parseList<string>(images)[0];
---

{
  src && (
    <figure>
      <CmsPicture src={src} alt={caption ?? ""} preset="content" loading="lazy" class="h-auto w-full rounded-lg" />
      {caption && <figcaption class="mt-2 text-sm text-gray-500">{caption}</figcaption>}
    </figure>
  )
}
