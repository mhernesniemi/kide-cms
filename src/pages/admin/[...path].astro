---
import { ArrowUpRight, Clock3, Globe2, Dot, Languages, Plus } from "lucide-react";

import AdminCard from "@/components/admin/AdminCard.astro";
import DocumentActions from "@/components/admin/DocumentActions";
import DocumentsDataTable from "@/components/admin/DocumentsDataTable";
import FieldControl from "@/components/admin/FieldControl.astro";
import { Badge, StatusBadge } from "@/components/admin/ui/badge";
import { buttonVariants } from "@/components/admin/ui/button";
import { Card, CardContent } from "@/components/admin/ui/card";
import config from "@/cms/collections.config";
import views from "@/cms/admin/views";
import { cms } from "@/cms/.generated/api";
import {
  formatDate,
  formatFieldValue,
  getFieldSets,
  getListColumns,
  humanize,
  initDateFormat,
  resolveAdminRoute,
} from "@/cms/core/admin";
import AdminLayout from "@/layouts/AdminLayout.astro";
export const prerender = false;

initDateFormat(config);
const cmsRuntime = cms as Record<string, any> & { meta: typeof cms.meta };
const route = resolveAdminRoute(Astro.params.path);
const user = Astro.locals.user;
const runtimeContext = user ? { user: { id: user.id, role: user.role, email: user.email } } : {};
const localeConfig = config.locales;
const locales = localeConfig?.supported ?? [];
const defaultLocale = localeConfig?.default ?? "en";
const requestedLocale = Astro.url.searchParams.get("locale") ?? defaultLocale;

// Redirect /admin to first collection
if (route.kind === "dashboard") {
  return Astro.redirect(config.collections[0] ? `/admin/${config.collections[0].slug}` : "/");
}

const getCollectionView = (slug: string) => (views as Record<string, any>)[slug] ?? {};
const getFormAction = (collectionSlug: string, documentId?: string) =>
  documentId ? `/api/cms/${collectionSlug}/${documentId}` : `/api/cms/${collectionSlug}`;

const getFieldSetTitle = (fields: string[], index: number) => {
  if (fields.includes("body") || fields.includes("blocks")) return "Content";
  if (
    fields.some((field) =>
      ["slug", "category", "author", "tags", "cover", "metadata", "sortOrder", "layout", "heroImage"].includes(field),
    )
  ) {
    return "Settings";
  }
  return index === 0 ? "Details" : "Configuration";
};

let collectionApi: any = null;
let viewConfig: Record<string, any> = {};
let docs: Array<Record<string, unknown>> = [];
let doc: Record<string, unknown> | null = null;
let baseDoc: Record<string, unknown> | null = null;
let relationOptionsByField: Record<string, Array<{ value: string; label: string }>> = {};
let versions: Array<{ version: number; createdAt: string }> = [];

const collection = cms.meta.getCollection(route.collectionSlug) as any;
collectionApi = cmsRuntime[route.collectionSlug];
viewConfig = getCollectionView(route.collectionSlug);

for (const [fieldName, field] of Object.entries(collection.fields) as [
  string,
  import("@/cms/core/define").FieldConfig,
][]) {
  if (field.type === "relation") {
    const relatedDocs = await cmsRuntime[field.collection].find(
      {
        status: "any",
        limit: 100,
        sort: { field: "_updatedAt", direction: "desc" },
        locale: defaultLocale,
      },
      runtimeContext,
    );

    relationOptionsByField[fieldName] = relatedDocs.map((item: Record<string, unknown>) => ({
      value: String(item._id),
      label: String(item.title ?? item.name ?? item.slug ?? item._id),
    }));
  }
}

if (route.kind === "list") {
  docs = await collectionApi.find(
    {
      status: "any",
      locale: defaultLocale,
      sort: viewConfig.list?.defaultSort ?? { field: "_updatedAt", direction: "desc" },
    },
    runtimeContext,
  );
}

if (route.kind === "edit") {
  doc = await collectionApi.findById(route.documentId, { status: "any", locale: requestedLocale }, runtimeContext);
  if (!doc) {
    return Astro.redirect(`/admin/${route.collectionSlug}`);
  }
  baseDoc =
    requestedLocale === defaultLocale
      ? doc
      : await collectionApi.findById(route.documentId, { status: "any", locale: defaultLocale }, runtimeContext);
  versions = await collectionApi.versions(route.documentId);
}

const selectedLocale = route.kind === "new" ? defaultLocale : requestedLocale;
const translatableFields = collection
  ? Object.entries(collection.fields)
      .filter(([, field]: [string, any]) => field.translatable)
      .map(([fieldName]) => fieldName)
  : [];
const translationMode =
  !!collection && route.kind === "edit" && selectedLocale !== defaultLocale && translatableFields.length > 0;
const sharedFields = collection
  ? Object.keys(collection.fields).filter((fieldName) => !translatableFields.includes(fieldName))
  : [];
const fieldSets = collection ? getFieldSets(collection, viewConfig.edit) : [];
const primaryFieldSets = fieldSets.filter((set: { width?: string }) => set.width !== "1/3");
const sidebarFieldSets = fieldSets.filter((set: { width?: string }) => set.width === "1/3");
const mainFieldSets = primaryFieldSets.length > 0 ? primaryFieldSets : fieldSets.slice(0, 1);
const effectiveSidebarFieldSets =
  sidebarFieldSets.length > 0 ? sidebarFieldSets : fieldSets.slice(mainFieldSets.length);
const listColumns = collection ? getListColumns(collection, viewConfig.list) : [];
const getCurrentValue = (fieldName: string) => (doc ? doc[fieldName] : undefined);
const getSharedValue = (fieldName: string) => (baseDoc ? baseDoc[fieldName] : undefined);

const tableRows =
  collection && route.kind === "list"
    ? docs.map((entry) => ({
        id: String(entry._id),
        editHref: `/admin/${collection.slug}/${entry._id}`,
        status: String(entry._status ?? "draft"),
        locales: [
          defaultLocale,
          ...(Array.isArray(entry._availableLocales) ? entry._availableLocales.map((locale) => String(locale)) : []),
        ],
        searchText: String(entry.title ?? entry.name ?? entry.slug ?? entry._id ?? ""),
        values: Object.fromEntries(
          listColumns.map((column) => [
            column,
            column === "_updatedAt" || column === "_createdAt"
              ? formatDate(entry[column])
              : column.startsWith("_")
                ? String(entry[column] ?? "—")
                : formatFieldValue(collection.fields[column], entry[column]),
          ]),
        ),
      }))
    : [];
---

<AdminLayout
  title={`${collection?.labels?.plural ?? "Admin"} | AstroCMS`}
  collections={config.collections}
  activeCollection={route.collectionSlug}
>
  <section class="space-y-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">
          {route.kind === "list" && collection.labels.plural}
          {route.kind === "new" && `New ${collection.labels.singular}`}
          {route.kind === "edit" && String(doc?.title ?? doc?.name ?? doc?.slug ?? collection.labels.singular)}
        </h1>
        {
          route.kind === "edit" && doc && (
            <div class="text-muted-foreground mt-1 flex items-center gap-1 text-xs">
              <StatusBadge status={String(doc._status ?? "draft")} />
              <span>Created {formatDate(doc._createdAt)}</span>
              <Dot className="size-6 text-muted-foreground/70" />
              <span>Updated {formatDate(doc._updatedAt)}</span>
            </div>
          )
        }
      </div>

      <div class="flex flex-wrap items-center gap-2">
        {
          route.kind !== "list" && (
            <a href={`/admin/${collection.slug}`} class={buttonVariants({ variant: "outline", size: "sm" })}>
              Back to list
            </a>
          )
        }
        {
          route.kind === "list" && (
            <a href={`/admin/${collection.slug}/new`} class={buttonVariants({ size: "sm" })}>
              <Plus className="size-4" />
              New {collection.labels.singular}
            </a>
          )
        }
      </div>
    </div>

    {
      route.kind === "list" && (
        <DocumentsDataTable
          client:load
          collectionSlug={collection.slug}
          draftsEnabled={collection.drafts}
          title={collection.labels.plural}
          columns={listColumns.map((column) => ({ key: column, label: humanize(column) }))}
          data={tableRows}
          searchPlaceholder={`Filter ${collection.labels.plural.toLowerCase()}...`}
        />
      )
    }

    {
      (route.kind === "new" || route.kind === "edit") && (
        <>
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex flex-wrap items-center gap-2">
              {locales.length > 1 &&
                route.kind === "edit" &&
                translatableFields.length > 0 &&
                locales.map((locale) => (
                  <a
                    href={`/admin/${collection.slug}/${route.documentId}?locale=${locale}`}
                    class={buttonVariants({
                      variant: selectedLocale === locale ? "secondary" : "outline",
                      size: "sm",
                    })}
                  >
                    <Globe2 className="size-4" />
                    {locale}
                  </a>
                ))}
            </div>
            <div class="flex flex-wrap items-center gap-2">
              <button
                class={buttonVariants({ variant: "outline" })}
                type="submit"
                form="document-form"
                name="_intent"
                value="save"
              >
                {collection.drafts ? "Save draft" : "Save"}
              </button>
              {collection.drafts && (
                <button class={buttonVariants()} type="submit" form="document-form" name="_intent" value="publish">
                  Publish
                </button>
              )}
              {route.kind === "edit" && (
                <DocumentActions
                  client:load
                  formId="document-form"
                  showUnpublish={collection.drafts && doc?._status === "published"}
                  showDelete={true}
                />
              )}
            </div>
          </div>

          {!translationMode && (
            <form
              id="document-form"
              method="post"
              action={getFormAction(collection.slug, route.kind === "edit" ? route.documentId : undefined)}
              class="grid gap-6 2xl:grid-cols-[minmax(0,1.55fr)_minmax(380px,460px)]"
            >
              <input type="hidden" name="_action" value={route.kind === "new" ? "create" : "update"} />
              <input type="hidden" name="redirectTo" value={Astro.url.pathname + Astro.url.search} />

              <div class="space-y-6">
                {mainFieldSets.map((set, index) => (
                  <AdminCard title={getFieldSetTitle(set.fields, index)}>
                    <div class="grid gap-5">
                      {set.fields.map((fieldName) => (
                        <FieldControl
                          name={fieldName}
                          field={collection.fields[fieldName]}
                          value={getCurrentValue(fieldName)}
                          relationOptions={relationOptionsByField[fieldName] ?? []}
                        />
                      ))}
                    </div>
                  </AdminCard>
                ))}
              </div>

              <div class="space-y-6">
                {effectiveSidebarFieldSets.map((set, index) => (
                  <AdminCard title={getFieldSetTitle(set.fields, index + mainFieldSets.length)}>
                    <div class="grid gap-5">
                      {set.fields.map((fieldName) => (
                        <FieldControl
                          name={fieldName}
                          field={collection.fields[fieldName]}
                          value={getCurrentValue(fieldName)}
                          relationOptions={relationOptionsByField[fieldName] ?? []}
                        />
                      ))}
                    </div>
                  </AdminCard>
                ))}

                {route.kind === "edit" && (
                  <>
                    {doc?.slug && (
                      <AdminCard title="Public route">
                        <a
                          href={cms.meta.getRouteForDocument(collection.slug, doc)}
                          target="_blank"
                          class="hover:bg-muted/50 flex items-center justify-between gap-3 rounded-lg border px-3 py-3 text-sm transition-colors"
                        >
                          <span class="truncate">{cms.meta.getRouteForDocument(collection.slug, doc)}</span>
                          <ArrowUpRight className="size-4 shrink-0 text-muted-foreground" />
                        </a>
                      </AdminCard>
                    )}

                    {versions.length > 0 && (
                      <AdminCard title="Version history">
                        <div class="grid gap-3">
                          {versions
                            .slice()
                            .reverse()
                            .map((version) => (
                              <div class="rounded-lg border px-3 py-3">
                                <div class="flex items-start justify-between gap-3">
                                  <div>
                                    <div class="flex items-center gap-2 font-medium">
                                      <Clock3 className="size-4 text-muted-foreground" />v{version.version}
                                    </div>
                                    <div class="text-muted-foreground mt-1 text-xs">{formatDate(version.createdAt)}</div>
                                  </div>
                                  <form method="post" action={getFormAction(collection.slug, route.documentId)}>
                                    <input type="hidden" name="_action" value="restore" />
                                    <input type="hidden" name="version" value={String(version.version)} />
                                    <input
                                      type="hidden"
                                      name="redirectTo"
                                      value={Astro.url.pathname + Astro.url.search}
                                    />
                                    <button class={buttonVariants({ variant: "outline", size: "sm" })} type="submit">
                                      Restore
                                    </button>
                                  </form>
                                </div>
                              </div>
                            ))}
                        </div>
                      </AdminCard>
                    )}
                  </>
                )}
              </div>
            </form>
          )}

          {translationMode && (
            <div class="grid gap-6 2xl:grid-cols-[minmax(0,1.55fr)_minmax(380px,460px)]">
              <div class="space-y-6">
                <Card>
                  <CardContent className="flex items-center gap-2 py-3 text-sm">
                    <Languages className="size-4" />
                    Editing {selectedLocale} translation — only translatable fields are editable.
                  </CardContent>
                </Card>

                <form method="post" action={getFormAction(collection.slug, route.documentId)} class="space-y-6">
                  <input type="hidden" name="_action" value="save-translation" />
                  <input type="hidden" name="locale" value={selectedLocale} />
                  <input type="hidden" name="redirectTo" value={Astro.url.pathname + Astro.url.search} />

                  <AdminCard title="Localized content">
                    <div class="grid gap-5">
                      {translatableFields.map((fieldName) => (
                        <FieldControl
                          name={fieldName}
                          field={collection.fields[fieldName]}
                          value={getCurrentValue(fieldName)}
                          relationOptions={relationOptionsByField[fieldName] ?? []}
                        />
                      ))}
                    </div>
                  </AdminCard>

                  <Card>
                    <CardContent className="flex justify-end py-4">
                      <button class={buttonVariants({ variant: "default" })} type="submit">
                        Save translation
                      </button>
                    </CardContent>
                  </Card>
                </form>
              </div>

              <div class="space-y-6">
                <AdminCard title="Shared fields">
                  <div class="grid gap-5">
                    {sharedFields.map((fieldName) => (
                      <FieldControl
                        name={fieldName}
                        field={collection.fields[fieldName]}
                        value={getSharedValue(fieldName)}
                        relationOptions={relationOptionsByField[fieldName] ?? []}
                        readOnly={true}
                      />
                    ))}
                  </div>
                </AdminCard>
              </div>
            </div>
          )}
        </>
      )
    }
  </section>
</AdminLayout>
