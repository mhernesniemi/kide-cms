---
import {
  ChevronRight,
  Folder,
  FolderPlus,
  GripVertical,
  ImagePlus,
  MoreHorizontal,
  Pencil,
  Trash2,
  Upload,
} from "lucide-react";

import { Badge } from "@/components/admin/ui/badge";
import { buttonVariants } from "@/components/admin/ui/button";
import { Card, CardContent } from "@/components/admin/ui/card";
import config from "@/cms/collections.config";
import { assets, folders } from "@/cms/core/assets";
import AdminLayout from "@/layouts/AdminLayout.astro";

export const prerender = false;

const currentFolderId = Astro.url.searchParams.get("folder") || null;

// Get current folder details if we're inside one
const currentFolder = currentFolderId ? await folders.findById(currentFolderId) : null;
if (currentFolderId && !currentFolder) return Astro.redirect("/admin/assets");

// Get subfolders and assets for current location
const subfolders = await folders.findByParent(currentFolderId);
const folderAssets = await assets.find({ limit: 100, folder: currentFolderId });

// Build breadcrumb trail
const breadcrumbs: Array<{ label: string; href: string; id: string }> = [];
if (currentFolder) {
  let folder: typeof currentFolder | null = currentFolder;
  const chain: typeof breadcrumbs = [];
  while (folder) {
    chain.unshift({ label: folder.name, href: `/admin/assets?folder=${folder._id}`, id: folder._id });
    folder = folder.parent ? await folders.findById(folder.parent) : null;
  }
  breadcrumbs.push(...chain);
}
---

<AdminLayout title="Assets | AstroCMS" collections={config.collections} activeCollection={null}>
  <section class="space-y-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold tracking-tight">Assets</h1>
        {
          breadcrumbs.length > 0 && (
            <nav class="text-muted-foreground mt-2 flex items-center gap-1 text-sm">
              <a
                href="/admin/assets"
                class="breadcrumb-drop-target hover:text-foreground hover:border-foreground/20 bg-muted/50 rounded-md border border-border px-2.5 py-1 transition-colors"
                data-folder-id=""
              >
                All assets
              </a>
              {breadcrumbs.map((crumb) => (
                <>
                  <ChevronRight className="size-3.5" />
                  <a
                    href={crumb.href}
                    class="breadcrumb-drop-target hover:text-foreground hover:border-foreground/20 bg-muted/50 rounded-md border border-border px-2.5 py-1 transition-colors"
                    data-folder-id={crumb.id}
                  >
                    {crumb.label}
                  </a>
                </>
              ))}
            </nav>
          )
        }
      </div>
      <div class="flex items-center gap-2">
        <div id="bulk-actions" class="hidden items-center gap-2">
          <span id="bulk-count" class="text-muted-foreground text-sm"></span>
          <button type="button" id="bulk-delete-btn" class={buttonVariants({ variant: "destructive", size: "sm" })}>
            <Trash2 className="size-3.5" />
            Delete
          </button>
          <button type="button" id="bulk-cancel-btn" class={buttonVariants({ variant: "outline", size: "sm" })}>
            Cancel
          </button>
        </div>
        <div id="default-actions" class="flex items-center gap-2">
          <button type="button" id="new-folder-btn" class={buttonVariants({ variant: "outline", size: "sm" })}>
            <FolderPlus className="size-4" />
            New folder
          </button>
          <label class={buttonVariants({ size: "sm" }) + " cursor-pointer"}>
            <Upload className="size-4" />
            Upload
            <form method="post" action="/api/cms/assets/upload" enctype="multipart/form-data" class="hidden">
              <input type="hidden" name="redirectTo" value="/admin/assets" />
              {currentFolderId && <input type="hidden" name="folder" value={currentFolderId} />}
              <input
                type="file"
                name="file"
                accept="image/*,video/*,audio/*,.pdf,.doc,.docx"
                required
                onchange="this.closest('form').submit()"
              />
            </form>
          </label>
        </div>
      </div>
    </div>

    {
      subfolders.length > 0 && (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5">
          {subfolders.map((folder) => (
            <div class="folder-drop-target group relative" data-folder-id={folder._id}>
              <a href={`/admin/assets?folder=${folder._id}`}>
                <Card className="transition-colors hover:border-foreground/20">
                  <CardContent className="flex items-center gap-3 py-3">
                    <Folder className="text-muted-foreground size-5" />
                    <span class="truncate text-sm font-medium">{folder.name}</span>
                  </CardContent>
                </Card>
              </a>
              <div class="absolute top-1/2 right-3 -translate-y-1/2 opacity-0 transition-opacity group-hover:opacity-100">
                <button
                  type="button"
                  class="folder-menu-btn text-muted-foreground hover:text-foreground rounded-md p-1"
                  data-folder-id={folder._id}
                  data-folder-name={folder.name}
                >
                  <MoreHorizontal className="size-4" />
                </button>
              </div>
            </div>
          ))}
        </div>
      )
    }

    {
      folderAssets.length === 0 && subfolders.length === 0 ? (
        <Card>
          <CardContent className="py-12">
            <div class="text-center">
              <ImagePlus className="mx-auto size-12 text-muted-foreground/30" />
              <p class="text-muted-foreground mt-3 text-sm">
                {currentFolderId ? "This folder is empty." : "No assets uploaded yet."}
              </p>
            </div>
          </CardContent>
        </Card>
      ) : (
        folderAssets.length > 0 && (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5">
            {folderAssets.map((asset) => (
              <div class="asset-card group relative" data-asset-id={asset._id}>
                <a href={`/admin/assets/${asset._id}`} class="block">
                  <Card className="overflow-hidden transition-colors hover:border-foreground/20 pt-0">
                    <div class="relative">
                      {asset.mimeType.startsWith("image/") ? (
                        <div class="bg-muted/30 aspect-square w-full overflow-hidden">
                          <img src={asset.url} alt={asset.alt ?? asset.filename} class="size-full object-cover" />
                        </div>
                      ) : (
                        <div class="bg-muted/30 flex aspect-square items-center justify-center">
                          <Badge variant="outline">{asset.mimeType}</Badge>
                        </div>
                      )}
                    </div>
                    <CardContent className="px-3">
                      <div class="truncate text-sm font-medium">{asset.filename}</div>
                      <div class="text-muted-foreground mt-0.5 text-xs">
                        {new Date(asset._createdAt).toLocaleDateString()}
                      </div>
                    </CardContent>
                  </Card>
                </a>
                {/* Checkbox overlay */}
                <label class="border-foreground/25 bg-background/80 has-[:checked]:border-primary has-[:checked]:bg-primary absolute top-2.5 right-2.5 z-10 flex size-5 cursor-pointer items-center justify-center rounded border opacity-0 backdrop-blur-sm transition-opacity group-hover:opacity-100 has-[:checked]:opacity-100">
                  <input type="checkbox" class="asset-checkbox peer sr-only" data-asset-id={asset._id} />
                  <svg
                    class="text-primary-foreground hidden size-3 peer-checked:block"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </label>
                {/* Drag handle */}
                <div
                  class="drag-handle bg-background/80 text-muted-foreground absolute top-2.5 left-2.5 z-10 flex size-5 cursor-grab items-center justify-center rounded opacity-0 backdrop-blur-sm transition-opacity group-hover:opacity-100"
                  data-asset-id={asset._id}
                >
                  <GripVertical className="size-3.5" />
                </div>
              </div>
            ))}
          </div>
        )
      )
    }
  </section>
</AdminLayout>

<style is:global>
  .drop-highlight [data-slot="card"] {
    border-color: var(--foreground) !important;
    background-color: color-mix(in oklch, var(--primary), transparent 92%);
  }
  .breadcrumb-drop-target.drop-highlight {
    background-color: color-mix(in oklch, var(--primary), transparent 88%);
    border-color: var(--primary) !important;
    color: var(--foreground);
  }
  .asset-card.dragging {
    opacity: 0.4;
  }
</style>

<!-- Folder context menu (hidden, shown on click) -->
<div
  id="folder-menu"
  class="bg-popover text-popover-foreground border-border fixed z-50 hidden min-w-[160px] rounded-md border p-1 shadow-md"
>
  <button
    type="button"
    id="folder-rename"
    class="hover:bg-accent flex w-full items-center gap-2 rounded-sm px-2 py-1.5 text-sm"
  >
    <Pencil className="size-3.5" />
    Rename
  </button>
  <button
    type="button"
    id="folder-delete"
    class="hover:bg-destructive hover:text-destructive-foreground flex w-full items-center gap-2 rounded-sm px-2 py-1.5 text-sm"
  >
    <Trash2 className="size-3.5" />
    Delete
  </button>
</div>

<script is:inline>
  // New folder creation
  var folderParam = new URLSearchParams(location.search).get("folder") || null;

  document.getElementById("new-folder-btn").addEventListener("click", function () {
    var name = prompt("Folder name:");
    if (!name || !name.trim()) return;

    fetch("/api/cms/assets/folders", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ action: "create", name: name.trim(), parent: folderParam }),
    }).then(function (res) {
      if (res.ok) location.reload();
      else alert("Failed to create folder.");
    });
  });

  // Keyboard shortcut
  document.addEventListener("keydown", function (e) {
    if ((e.metaKey || e.ctrlKey) && e.shiftKey && e.key === "n") {
      e.preventDefault();
      document.getElementById("new-folder-btn").click();
    }
  });

  // Folder context menu
  var menu = document.getElementById("folder-menu");
  var activeFolderId = null;
  var activeFolderName = null;

  document.querySelectorAll(".folder-menu-btn").forEach(function (btn) {
    btn.addEventListener("click", function (e) {
      e.preventDefault();
      e.stopPropagation();
      activeFolderId = btn.dataset.folderId;
      activeFolderName = btn.dataset.folderName;
      var rect = btn.getBoundingClientRect();
      menu.style.top = rect.bottom + 4 + "px";
      menu.style.left = rect.right - 160 + "px";
      menu.classList.remove("hidden");
    });
  });

  document.addEventListener("click", function () {
    menu.classList.add("hidden");
  });

  document.getElementById("folder-rename").addEventListener("click", function (e) {
    e.stopPropagation();
    menu.classList.add("hidden");
    var newName = prompt("Rename folder:", activeFolderName);
    if (!newName || !newName.trim() || newName.trim() === activeFolderName) return;

    fetch("/api/cms/assets/folders", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ action: "rename", id: activeFolderId, name: newName.trim() }),
    }).then(function (res) {
      if (res.ok) location.reload();
      else alert("Failed to rename folder.");
    });
  });

  document.getElementById("folder-delete").addEventListener("click", function (e) {
    e.stopPropagation();
    menu.classList.add("hidden");
    if (!confirm("Delete this folder? Assets will be moved to root.")) return;

    fetch("/api/cms/assets/folders", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ action: "delete", id: activeFolderId }),
    }).then(function (res) {
      if (res.ok) location.reload();
      else alert("Failed to delete folder.");
    });
  });

  // Bulk selection
  var bulkActions = document.getElementById("bulk-actions");
  var defaultActions = document.getElementById("default-actions");
  var bulkCount = document.getElementById("bulk-count");

  function getSelected() {
    return Array.from(document.querySelectorAll(".asset-checkbox:checked")).map(function (cb) {
      return cb.dataset.assetId;
    });
  }

  function updateBulkUI() {
    var selected = getSelected();
    if (selected.length > 0) {
      bulkActions.classList.remove("hidden");
      bulkActions.classList.add("flex");
      defaultActions.classList.add("hidden");
      bulkCount.textContent = selected.length + " selected";
    } else {
      bulkActions.classList.add("hidden");
      bulkActions.classList.remove("flex");
      defaultActions.classList.remove("hidden");
    }
  }

  document.querySelectorAll(".asset-checkbox").forEach(function (cb) {
    cb.addEventListener("change", updateBulkUI);
    cb.closest("label").addEventListener("click", function (e) {
      e.stopPropagation();
    });
  });

  document.getElementById("bulk-delete-btn").addEventListener("click", function () {
    var selected = getSelected();
    if (!selected.length) return;
    if (!confirm("Delete " + selected.length + " asset" + (selected.length > 1 ? "s" : "") + "?")) return;

    Promise.all(
      selected.map(function (id) {
        return fetch("/api/cms/assets/" + id, { method: "DELETE" });
      }),
    ).then(function () {
      location.reload();
    });
  });

  document.getElementById("bulk-cancel-btn").addEventListener("click", function () {
    document.querySelectorAll(".asset-checkbox:checked").forEach(function (cb) {
      cb.checked = false;
    });
    updateBulkUI();
  });

  // Drag and drop (mouse-based)
  var dragging = false;
  var dragAssetId = null;
  var dragCard = null;
  var dragGhost = null;
  var dragOffsetX = 0;
  var dragOffsetY = 0;
  var currentDropTarget = null;
  var DRAG_THRESHOLD = 5;
  var startX = 0;
  var startY = 0;
  var mouseIsDown = false;
  var activeHandle = null;

  var dropTargets = [];
  document.querySelectorAll(".folder-drop-target").forEach(function (el) {
    dropTargets.push(el);
  });
  document.querySelectorAll(".breadcrumb-drop-target").forEach(function (el) {
    dropTargets.push(el);
  });

  document.querySelectorAll(".drag-handle").forEach(function (handle) {
    handle.addEventListener("mousedown", function (e) {
      if (e.button !== 0) return;
      e.preventDefault();
      mouseIsDown = true;
      activeHandle = handle;
      startX = e.clientX;
      startY = e.clientY;
    });
  });

  document.addEventListener("mousemove", function (e) {
    if (!mouseIsDown) return;

    if (!dragging) {
      var dx = e.clientX - startX;
      var dy = e.clientY - startY;
      if (Math.abs(dx) < DRAG_THRESHOLD && Math.abs(dy) < DRAG_THRESHOLD) return;

      // Start drag
      dragging = true;
      dragCard = activeHandle.closest(".asset-card");
      dragAssetId = activeHandle.dataset.assetId;

      // Create ghost
      var cardEl = dragCard.querySelector("[data-slot='card']");
      var rect = cardEl.getBoundingClientRect();
      dragGhost = cardEl.cloneNode(true);
      dragGhost.style.position = "fixed";
      dragGhost.style.width = rect.width + "px";
      dragGhost.style.zIndex = "9999";
      dragGhost.style.pointerEvents = "none";
      dragGhost.style.opacity = "0.85";
      dragGhost.style.transform = "rotate(2deg) scale(0.95)";
      dragGhost.style.boxShadow = "0 8px 25px rgba(0,0,0,0.2)";
      dragGhost.style.transition = "none";
      document.body.appendChild(dragGhost);

      var handleRect = activeHandle.getBoundingClientRect();
      dragOffsetX = handleRect.left - rect.left + handleRect.width / 2;
      dragOffsetY = handleRect.top - rect.top + handleRect.height / 2;

      dragCard.classList.add("dragging");
      document.body.style.cursor = "grabbing";
      document.body.style.userSelect = "none";
    }

    // Move ghost
    if (dragGhost) {
      dragGhost.style.left = e.clientX - dragOffsetX + "px";
      dragGhost.style.top = e.clientY - dragOffsetY + "px";
    }

    // Hit-test drop targets
    var hit = null;
    for (var i = 0; i < dropTargets.length; i++) {
      var r = dropTargets[i].getBoundingClientRect();
      if (e.clientX >= r.left && e.clientX <= r.right && e.clientY >= r.top && e.clientY <= r.bottom) {
        hit = dropTargets[i];
        break;
      }
    }
    if (hit !== currentDropTarget) {
      if (currentDropTarget) currentDropTarget.classList.remove("drop-highlight");
      currentDropTarget = hit;
      if (currentDropTarget) currentDropTarget.classList.add("drop-highlight");
    }
  });

  document.addEventListener("mouseup", function () {
    if (!mouseIsDown) return;
    mouseIsDown = false;

    if (!dragging) {
      activeHandle = null;
      return;
    }

    // Drop
    if (currentDropTarget && dragAssetId) {
      var targetFolderId = currentDropTarget.dataset.folderId;
      fetch("/api/cms/assets/" + dragAssetId, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ folder: targetFolderId || null }),
      }).then(function (res) {
        if (res.ok) location.reload();
        else alert("Failed to move asset.");
      });
    }

    // Cleanup
    if (dragGhost) {
      dragGhost.remove();
      dragGhost = null;
    }
    if (dragCard) {
      dragCard.classList.remove("dragging");
      dragCard = null;
    }
    if (currentDropTarget) {
      currentDropTarget.classList.remove("drop-highlight");
      currentDropTarget = null;
    }
    document.body.style.cursor = "";
    document.body.style.userSelect = "";
    dragging = false;
    dragAssetId = null;
    activeHandle = null;
  });
</script>
