---
import PublicLayout from "@/layouts/PublicLayout.astro";
import BlockRenderer from "@/components/BlockRenderer.astro";
import { cms } from "@/cms/.generated/api";
import { cacheTags, parseBlocks } from "@/cms/core/content";

export const prerender = false;

const slug = (Astro.params.slug ?? "").split("/").filter(Boolean).join("/");
if (!slug) return Astro.redirect("/");

const isPreview = Astro.url.searchParams.get("preview") === "true";
const doc = await cms.pages.findOne({ slug, status: isPreview ? "any" : "published" });
if (!doc) return Astro.redirect("/");
if (!isPreview) Astro.cache.set({ tags: cacheTags("pages", doc._id) });
const blocks = parseBlocks(doc.blocks);
---

<PublicLayout title={doc.title}>
  <article class="mx-auto max-w-2xl px-4 py-8">
    <a href="/" class="text-sm text-teal-700">&larr; Back</a>
    <h1 class="mt-4 mb-2 text-2xl font-semibold">{doc.title}</h1>
    {doc.summary && <p class="mb-6 text-gray-500">{doc.summary}</p>}
    <BlockRenderer blocks={blocks} />
  </article>
</PublicLayout>
