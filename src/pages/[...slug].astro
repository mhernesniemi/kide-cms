---
import PublicLayout from "../layouts/PublicLayout.astro";
import RichTextContent from "../components/RichTextContent.astro";
import BlockRenderer from "../components/BlockRenderer.astro";
import PreviewReceiver from "../components/PreviewReceiver.astro";
import { cms } from "../cms/.generated/api";
import { cmsImage, cmsSrcset } from "../cms/core/image";

export const prerender = false;

type AnyRecord = Record<string, any>;

const segments = (Astro.params.slug ?? "").split("/").filter(Boolean);
const isPreview = Astro.url.searchParams.get("preview") === "true";

let document: AnyRecord | null = null;
let kind: "post" | "page" | null = null;

if (segments[0] === "blog" && segments[1]) {
  document = await cms.posts.findOne({
    slug: segments[1],
    status: isPreview ? "any" : "published",
  });
  kind = "post";
}

if (!document && segments.length >= 1) {
  document = await cms.pages.findOne({
    slug: segments.join("/"),
    status: isPreview ? "any" : "published",
  });
  kind = "page";
}

if (!document) {
  return Astro.redirect("/");
}

if (!isPreview) {
  const tag = kind === "post" ? "posts" : "pages";
  Astro.cache.set({ tags: [tag, `${tag.slice(0, -1)}:${document._id}`] });
}

const blocks = (() => {
  if (!document.blocks) return [];
  try {
    return typeof document.blocks === "string" ? JSON.parse(document.blocks) : document.blocks;
  } catch {
    return [];
  }
})();
---

<PublicLayout title={String(document.title)}>
  <article class="mx-auto max-w-2xl px-4 py-8">
    <a href="/" class="text-sm text-teal-700">&larr; Back</a>
    <h1 data-preview-field="title" class="mt-4 mb-2 text-2xl font-semibold">{String(document.title)}</h1>
    {
      kind === "post" && document.image && (
        <img
          data-preview-field="image"
          src={cmsImage(String(document.image), 1024)}
          srcset={cmsSrcset(String(document.image))}
          sizes="(max-width: 640px) 100vw, 640px"
          alt={String(document.title)}
          loading="eager"
          class="mb-6 h-auto w-full rounded-lg"
        />
      )
    }
    {
      kind === "post" && (document.excerpt || isPreview) && (
        <p data-preview-field="excerpt" class="mb-6 text-gray-500">
          {document.excerpt ? String(document.excerpt) : ""}
        </p>
      )
    }
    {
      kind === "post" && (
        <div data-preview-field="body" data-preview-type="richText" class="prose">
          <RichTextContent content={document.body} />
        </div>
      )
    }
    {
      kind === "page" && (
        <>
          {(document.summary || isPreview) && (
            <p data-preview-field="summary" class="mb-6 text-gray-500">
              {document.summary ? String(document.summary) : ""}
            </p>
          )}
          <div data-preview-field="blocks" data-preview-type="blocks">
            <BlockRenderer blocks={blocks} />
          </div>
        </>
      )
    }
  </article>
  {isPreview && <PreviewReceiver />}
</PublicLayout>
