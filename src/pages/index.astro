---
import PublicLayout from "@/layouts/PublicLayout.astro";
import type { PostsDocument } from "@/cms/.generated/types";
import { cms } from "@/cms/.generated/api";
import { cmsImage } from "@/cms/core/image";

const posts = await cms.posts.find({
  status: "published",
  sort: { field: "sortOrder", direction: "desc" },
});

Astro.cache.set({ tags: ["posts", "home"] });
---

<PublicLayout title="Kide CMS">
  <main class="mx-auto max-w-2xl px-4 py-8">
    <h1 class="mb-1 text-2xl font-semibold">Kide CMS</h1>
    <p class="mb-8 text-gray-500">
      <a href="/admin" class="text-teal-700 hover:underline">Admin</a>
    </p>

    <h2 class="mb-4 text-lg font-medium text-gray-700">Posts</h2>
    <ul class="grid list-none gap-2 p-0">
      {
        posts.map((post: PostsDocument) => (
          <li class="flex items-start gap-4">
            {post.image && (
              <a href={`/blog/${post.slug}`} class="shrink-0">
                <img
                  src={cmsImage(post.image, 320)}
                  alt={post.title}
                  loading="lazy"
                  class="size-20 rounded-md object-cover"
                />
              </a>
            )}
            <div>
              <a href={`/blog/${post.slug}`} class="text-teal-700 hover:underline">
                {post.title}
              </a>
              {post.excerpt && <p class="mt-1 text-sm text-gray-500">{post.excerpt}</p>}
            </div>
          </li>
        ))
      }
    </ul>

    {posts.length === 0 && <p class="text-gray-500">No published posts yet.</p>}
  </main>
</PublicLayout>
