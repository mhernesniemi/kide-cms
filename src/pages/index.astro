---
import PublicLayout from "@/layouts/PublicLayout.astro";
import BlockRenderer from "@/components/BlockRenderer.astro";
import type { PostsDocument } from "@/cms/.generated/types";
import { cms } from "@/cms/.generated/api";
import { cmsImage } from "@/cms/core/image";
import { parseBlocks } from "@/cms/core/content";

const page = await cms["front-page"].findOne({ status: "published" });
const blocks = parseBlocks(page?.blocks);

const posts = await cms.posts.find({
  status: "published",
  sort: { field: "sortOrder", direction: "desc" },
});

Astro.cache.set({ tags: ["front-page", "posts", "home"] });
---

<PublicLayout title="Kide CMS">
  <main class="mx-auto max-w-2xl px-4 py-8">
    <h2 class="mb-3 text-xl font-semibold">Recent posts</h2>
    <ul class="grid list-none gap-2 p-0">
      {
        posts.map((post: PostsDocument) => (
          <li class="flex items-start gap-4">
            {post.image && (
              <a href={`/blog/${post.slug}`} class="shrink-0">
                <img
                  src={cmsImage(post.image, 320)}
                  alt={post.title}
                  loading="lazy"
                  class="size-20 rounded-md object-cover"
                />
              </a>
            )}
            <div>
              <a href={`/blog/${post.slug}`} class="text-teal-700 hover:underline">
                {post.title}
              </a>
              {post.excerpt && <p class="mt-1 text-sm text-gray-500">{post.excerpt}</p>}
            </div>
          </li>
        ))
      }
    </ul>

    {posts.length === 0 && <p class="mb-10 text-gray-500">No published posts yet.</p>}
    {blocks.length > 0 && <BlockRenderer blocks={blocks} />}
  </main>
</PublicLayout>
