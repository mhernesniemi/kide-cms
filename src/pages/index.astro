---
import PublicLayout from "../layouts/PublicLayout.astro";
import { cms } from "../cms/.generated/api";
import { cmsImage } from "../cms/core/image";

export const prerender = false;

type AnyRecord = Record<string, any>;

const posts = (await cms.posts.find({
  status: "published",
  sort: { field: "sortOrder", direction: "desc" },
})) as AnyRecord[];

Astro.cache.set({ tags: ["posts", "home"] });

const rendered = new Date().toISOString();
---

<PublicLayout title="Kide CMS">
  <main style="max-width: 640px; margin: 0 auto; padding: 2rem 1rem;">
    <h1 style="font-size: 1.5rem; margin: 0 0 0.25rem;">Kide CMS</h1>
    <p style="color: #666; margin: 0 0 2rem;">
      <a href="/admin" style="color: #0f766e;">Admin</a>
    </p>

    <h2 style="font-size: 1.1rem; margin: 0 0 1rem; color: #333;">Posts</h2>
    <ul style="list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem;">
      {
        posts.map((post) => (
          <li style="display: flex; gap: 1rem; align-items: start;">
            {post.image && (
              <a href={`/blog/${post.slug}`} style="flex-shrink: 0;">
                <img
                  src={cmsImage(String(post.image), 320)}
                  alt={String(post.title)}
                  loading="lazy"
                  style="width: 120px; height: 80px; object-fit: cover; border-radius: 0.375rem;"
                />
              </a>
            )}
            <div>
              <a href={`/blog/${post.slug}`} style="color: #0f766e;">
                {String(post.title)}
              </a>
              {post.excerpt && (
                <p style="color: #999; font-size: 0.9rem; margin: 0.25rem 0 0;">{String(post.excerpt)}</p>
              )}
            </div>
          </li>
        ))
      }
    </ul>

    {posts.length === 0 && <p style="color: #999;">No published posts yet.</p>}

    <p style="color: #ccc; font-size: 0.75rem; margin-top: 2rem;">Rendered: {rendered}</p>
  </main>
</PublicLayout>
