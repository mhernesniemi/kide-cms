---
import PublicLayout from "@/layouts/PublicLayout.astro";
---

<PublicLayout title="Checkout cancelled">
  <main class="mx-auto max-w-xl px-4 py-16">
    <h1 class="text-2xl font-semibold">Checkout cancelled</h1>
    <p class="mt-2 text-gray-600">No payment was taken. Your cart is still here if you want to try again.</p>
    <a href="/" class="mt-8 inline-block text-sm text-teal-700 underline-offset-2 hover:underline"> Back to home </a>
  </main>
</PublicLayout>
