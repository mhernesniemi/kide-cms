---
import "../styles/admin.css";

import { FileText, Image, LayoutGrid, Menu, Newspaper, PencilRuler, Tags, Users } from "lucide-react";

import MobileSidebar from "@/components/admin/MobileSidebar";
import SidebarUserMenu from "@/components/admin/SidebarUserMenu";
import Toast from "@/components/admin/Toast.astro";
import { Separator } from "@/components/admin/ui/separator";
import { cn } from "@/lib/utils";

const {
  title = "Admin",
  collections = [],
  activeCollection = null,
} = Astro.props as {
  title?: string;
  collections?: Array<{ slug: string; labels: { plural: string } }>;
  activeCollection?: string | null;
};

const user = Astro.locals.user;

// Server-side toast: read _toast/_msg params set by API redirect
const toastStatus = Astro.url.searchParams.get("_toast") as "success" | "error" | null;
const toastMessage =
  Astro.url.searchParams.get("_msg") ?? (toastStatus === "success" ? "Saved successfully" : "Something went wrong");

const iconMap: Record<string, any> = {
  posts: Newspaper,
  pages: FileText,
  authors: PencilRuler,
  users: Users,
  taxonomies: Tags,
  menus: Menu,
};

const navItems = collections.map((collection) => ({
  ...collection,
  Icon: iconMap[collection.slug as keyof typeof iconMap] ?? LayoutGrid,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var t = localStorage.getItem("admin-theme") || "system";
        var dark = t === "dark" || (t === "system" && matchMedia("(prefers-color-scheme: dark)").matches);
        if (dark) document.documentElement.classList.add("dark");
      })();
    </script>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <div class="min-h-screen lg:grid lg:grid-cols-[17rem_minmax(0,1fr)]">
      {/* ── Desktop sidebar ──────────────────────────────────────────── */}
      <aside class="bg-sidebar/40 mt-1 hidden border-r backdrop-blur lg:flex lg:flex-col">
        <div class="px-3 pt-3 pb-2">
          {
            user && (
              <SidebarUserMenu
                client:load
                userName={user.name}
                userEmail={user.email}
                logoutAction="/api/cms/auth/logout"
              />
            )
          }
        </div>

        <nav class="flex-1 space-y-1 overflow-y-auto px-3 py-3">
          {
            navItems.map((item) => (
              <a
                href={`/admin/${item.slug}`}
                class={cn(
                  "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
                  activeCollection === item.slug
                    ? "bg-accent text-accent-foreground"
                    : "text-foreground/70 hover:bg-accent/60 hover:text-foreground",
                )}
              >
                <item.Icon className="size-4 shrink-0 stroke-1" />
                <span>{item.labels.plural}</span>
              </a>
            ))
          }
          <a
            href="/admin/assets"
            class={cn(
              "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
              "text-foreground/70 hover:bg-accent/60 hover:text-foreground",
            )}
          >
            <Image className="size-4 shrink-0 stroke-1" />
            <span>Assets</span>
          </a>
        </nav>
      </aside>

      <div class="min-w-0">
        {/* ── Mobile header ────────────────────────────────────────── */}
        <header
          class="bg-background/95 supports-backdrop-filter:bg-background/75 flex items-center gap-3 border-b px-4 py-3 backdrop-blur lg:hidden"
        >
          <MobileSidebar client:load>
            <div class="px-3 pt-3 pb-1">
              {
                user && (
                  <SidebarUserMenu
                    client:load
                    userName={user.name}
                    userEmail={user.email}
                    logoutAction="/api/cms/auth/logout"
                  />
                )
              }
              <Separator className="mt-3" />
            </div>

            <nav class="flex-1 space-y-1 overflow-y-auto px-3 py-3">
              {
                navItems.map((item) => (
                  <a
                    href={`/admin/${item.slug}`}
                    class={cn(
                      "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
                      activeCollection === item.slug
                        ? "bg-accent text-accent-foreground"
                        : "text-foreground/70 hover:bg-accent/60 hover:text-foreground",
                    )}
                  >
                    <item.Icon className="size-4 shrink-0 stroke-1" />
                    <span>{item.labels.plural}</span>
                  </a>
                ))
              }
              <a
                href="/admin/assets"
                class={cn(
                  "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
                  "text-foreground/70 hover:bg-accent/60 hover:text-foreground",
                )}
              >
                <Image className="size-4 shrink-0 stroke-1" />
                <span>Assets</span>
              </a>
            </nav>
          </MobileSidebar>
        </header>

        <main class="mx-auto w-full max-w-[1900px] px-4 py-6 lg:px-8 lg:py-8">
          <slot />
        </main>
      </div>
    </div>

    {toastStatus && <Toast status={toastStatus} message={toastMessage} />}

    {/* Clean toast params from URL and remove toast element after animation */}
    <script is:inline>
      (function () {
        var p = new URLSearchParams(location.search);
        var status = p.get("_toast");
        if (!status) return;
        p.delete("_toast");
        p.delete("_msg");
        history.replaceState({}, "", location.pathname + (p.size ? "?" + p : ""));
        // Error toasts stay longer (5s) than success toasts (3s)
        var delay = status === "error" ? 5200 : 3200;
        setTimeout(function () {
          var el = document.getElementById("admin-toast");
          if (el) el.remove();
        }, delay);
      })();
    </script>
  </body>
</html>
