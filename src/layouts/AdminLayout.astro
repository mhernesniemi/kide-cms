---
import "../styles/global.css";

import { Boxes, FileText, Image, LayoutGrid, LogOut, Newspaper, PencilRuler, Users } from "lucide-react";

import { buttonVariants } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import { cn } from "@/lib/utils";

const {
  title = "Admin",
  collections = [],
  activeCollection = null,
} = Astro.props as {
  title?: string;
  collections?: Array<{ slug: string; labels: { plural: string } }>;
  activeCollection?: string | null;
};

const user = Astro.locals.user;

const iconMap: Record<string, any> = {
  posts: Newspaper,
  pages: FileText,
  authors: PencilRuler,
  users: Users,
};

const navItems = collections.map((collection) => ({
  ...collection,
  Icon: iconMap[collection.slug as keyof typeof iconMap] ?? LayoutGrid,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body data-admin class="bg-background text-foreground min-h-screen antialiased">
    <div class="min-h-screen lg:grid lg:grid-cols-[17rem_minmax(0,1fr)]">
      <aside class="bg-sidebar/40 hidden border-r backdrop-blur lg:flex lg:flex-col">
        <div class="px-5 py-5">
          <a href="/admin" class="hover:bg-accent/50 flex items-start gap-3 rounded-lg px-2 py-1 transition-colors">
            <div class="bg-background rounded-lg border p-2 shadow-sm">
              <Boxes className="size-4" />
            </div>
            <div class="min-w-0">
              <div class="text-sm font-semibold tracking-tight">AstroCMS</div>
              <div class="text-muted-foreground text-xs">Content administration</div>
            </div>
          </a>
        </div>

        <Separator />

        <nav class="flex-1 space-y-1 px-3 py-4">
          {
            navItems.map((item) => (
              <a
                href={`/admin/${item.slug}`}
                class={cn(
                  "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors",
                  activeCollection === item.slug
                    ? "bg-accent text-accent-foreground"
                    : "text-muted-foreground hover:bg-accent/60 hover:text-foreground",
                )}
              >
                <item.Icon className="size-4 shrink-0" />
                <span>{item.labels.plural}</span>
              </a>
            ))
          }
          <a
            href="/admin/assets"
            class={cn(
              "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors",
              "text-muted-foreground hover:bg-accent/60 hover:text-foreground",
            )}
          >
            <Image className="size-4 shrink-0" />
            <span>Assets</span>
          </a>
        </nav>

        <div class="mt-auto px-3 pb-4">
          <Separator className="mb-4" />
          {
            user && (
              <div class="mb-3 flex items-center gap-3 rounded-lg px-3 py-2">
                <div class="bg-primary text-primary-foreground flex size-8 items-center justify-center rounded-full text-xs font-medium">
                  {user.name.charAt(0).toUpperCase()}
                </div>
                <div class="min-w-0 flex-1">
                  <div class="truncate text-sm font-medium">{user.name}</div>
                  <div class="text-muted-foreground truncate text-xs">{user.role}</div>
                </div>
              </div>
            )
          }
          <div class="space-y-2">
            <a href="/" class={cn(buttonVariants({ variant: "outline", size: "sm" }), "w-full justify-start")}>
              View site
            </a>
            {
              user && (
                <form method="post" action="/api/cms/auth/logout">
                  <button
                    type="submit"
                    class={cn(buttonVariants({ variant: "ghost", size: "sm" }), "w-full justify-start")}
                  >
                    <LogOut className="size-4" />
                    Sign out
                  </button>
                </form>
              )
            }
          </div>
        </div>
      </aside>

      <div class="min-w-0">
        <header class="bg-background/95 supports-[backdrop-filter]:bg-background/75 border-b backdrop-blur lg:hidden">
          <div class="flex items-center justify-between px-4 py-4">
            <a href="/admin" class="flex items-center gap-3">
              <div class="bg-card rounded-lg border p-2 shadow-sm">
                <Boxes className="size-4" />
              </div>
              <div>
                <div class="text-sm font-semibold">AstroCMS</div>
                <div class="text-muted-foreground text-xs">CMS admin</div>
              </div>
            </a>
            <a href="/" class={buttonVariants({ variant: "outline", size: "sm" })}>View site</a>
          </div>
          <div class="flex gap-2 overflow-x-auto px-4 pb-4">
            {
              navItems.map((item) => (
                <a
                  href={`/admin/${item.slug}`}
                  class={cn(
                    "inline-flex items-center gap-2 rounded-lg border px-3 py-2 text-sm whitespace-nowrap transition-colors",
                    activeCollection === item.slug
                      ? "bg-accent text-accent-foreground"
                      : "bg-card text-muted-foreground",
                  )}
                >
                  <item.Icon className="size-4" />
                  {item.labels.plural}
                </a>
              ))
            }
          </div>
        </header>

        <main class="mx-auto w-full max-w-[1900px] px-4 py-6 lg:px-8 lg:py-8">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
