---
const { eyebrow, heading, body, ctaLabel, ctaHref } = Astro.props;
---

<section class="text-center">
  {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-teal-700">{eyebrow}</p>}
  <h1 class="mb-3 text-3xl font-semibold">{heading}</h1>
  {body && <p class="mb-4 text-gray-500">{body}</p>}
  {
    ctaLabel && ctaHref && (
      <a href={String(ctaHref)} class="mt-4 inline-block rounded-md bg-teal-700 px-4 py-2 text-sm text-white no-underline">
        {ctaLabel}
      </a>
    )
  }
</section>
